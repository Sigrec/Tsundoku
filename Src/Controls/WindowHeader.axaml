<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="clr-namespace:Projektanker.Icons.Avalonia;assembly=Projektanker.Icons.Avalonia"
        xmlns:controls="using:Tsundoku.Controls">
	<Style Selector="controls|WindowHeader">
		<Setter Property="Template">
			<ControlTemplate>
				<Border BorderThickness="0,0,0,2" BorderBrush="{DynamicResource TsundokuDividerColor}" Padding="16,12">
					<StackPanel Orientation="Horizontal" Spacing="8">
						<i:Icon Value="{TemplateBinding Icon}" FontSize="16" Foreground="{DynamicResource TsundokuDividerColor}"/>
						<TextBlock Text="{TemplateBinding Title}" FontSize="18" FontWeight="ExtraBold" Foreground="{DynamicResource TsundokuUsernameColor}" VerticalAlignment="Center"/>
					</StackPanel>
				</Border>
			</ControlTemplate>
		</Setter>
	</Style>
</Styles>
