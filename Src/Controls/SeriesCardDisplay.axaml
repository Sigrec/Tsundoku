<!-- File: Controls/SeriesCardDisplay.axaml -->
<UserControl
    x:Class="Tsundoku.Controls.SeriesCardDisplay"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:m="clr-namespace:Tsundoku.Models;assembly=Tsundoku"
    xmlns:cv="clr-namespace:Tsundoku.Converters;assembly=Tsundoku"
    xmlns:i="clr-namespace:Projektanker.Icons.Avalonia;assembly=Projektanker.Icons.Avalonia"
    xmlns:controls="clr-namespace:Tsundoku.Controls"
    x:Name="Root"
    x:DataType="controls:SeriesCardDisplay">

  <UserControl.Styles>
    <StyleInclude Source="avares://Tsundoku/Styles/CardScrollBarStyles.axaml"/>
    <Style Selector="Image.cover-img">
      <Setter Property="RenderTransform" Value="scale(1, 1)"/>
      <Setter Property="Transitions">
        <Transitions>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.card-hover:pointerover Image.cover-img">
      <Setter Property="RenderTransform" Value="scale(1.05, 1.05)"/>
    </Style>
    <!-- Glassmorphism: reduce solid BG opacity and show acrylic when GlassEnabled is true -->
    <Style Selector="controls|SeriesCardDisplay[GlassEnabled=True] Border#CardSolidBG">
      <Setter Property="Opacity" Value="0.3"/>
    </Style>
    <Style Selector="controls|SeriesCardDisplay[GlassEnabled=True] ExperimentalAcrylicBorder#CardAcrylicBorder">
      <Setter Property="IsVisible" Value="True"/>
    </Style>
  </UserControl.Styles>

  <UserControl.Resources>
    <ResourceDictionary>
      <cv:TitleLangConverter x:Key="ConvertTitle"/>
      <cv:StaffLangConverter x:Key="ConvertStaff"/>
    </ResourceDictionary>
  </UserControl.Resources>

  <!-- KEY: Bind Content to Series so the template only materializes when Series != null -->
  <ContentControl Content="{CompiledBinding Series, ElementName=Root}">
    <ContentControl.ContentTemplate>
      <DataTemplate x:DataType="m:Series">

        <Border
            Name="CardBorder"
            Margin="12"
            CornerRadius="14"
            BorderThickness="2"
            BorderBrush="{DynamicResource TsundokuSeriesCardBorderColor}"
            BoxShadow="0 0 15 6 #B3000000"
            Width="{CompiledBinding Source={x:Static m:Constants.CARD_WIDTH}}"
            Height="{CompiledBinding Source={x:Static m:Constants.CARD_HEIGHT}}"
            UseLayoutRounding="True"
            Classes="card-hover">
          <Border.Styles>
            <Style Selector="Border.card-hover">
              <Setter Property="RenderTransform" Value="translate(0px, 0px)"/>
            </Style>
            <Style Selector="Border.card-hover:pointerover">
              <Setter Property="RenderTransform" Value="translate(0px, -4px)"/>
            </Style>
          </Border.Styles>
          <Border.Transitions>
            <Transitions>
              <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut"/>
            </Transitions>
          </Border.Transitions>

          <Border CornerRadius="14" ClipToBounds="True" Name="CardInner">
            <Grid ColumnDefinitions="Auto,*">

              <!-- ── Hover + ToolTip Styles ── -->
              <Grid.Styles>
                <Style Selector="ToolTip">
                  <Setter Property="Background" Value="{DynamicResource TsundokuStatusAndBookTypeBGColor}"/>
                  <Setter Property="BorderBrush" Value="{DynamicResource TsundokuMenuButtonBorderColor}"/>
                  <Setter Property="Foreground" Value="{DynamicResource TsundokuMenuButtonTextAndIconColor}"/>
                </Style>
              </Grid.Styles>

              <!-- ── Left Side: Cover ── -->
              <Panel
                  Grid.Column="0"
                  Width="{CompiledBinding Source={x:Static m:Constants.LEFT_SIDE_CARD_WIDTH}}"
                  PointerPressed="OpenSiteLink"
                  Cursor="Hand"
                  Background="{DynamicResource TsundokuSeriesCoverBGColor}">

                <!-- Cover Image (full height) -->
                <Image
                    Classes="cover-img"
                    Height="{CompiledBinding Source={x:Static m:Constants.IMAGE_HEIGHT}}"
                    Width="{CompiledBinding Source={x:Static m:Constants.LEFT_SIDE_CARD_WIDTH}}"
                    Source="{CompiledBinding CoverBitMap}"
                    RenderOptions.BitmapInterpolationMode="LowQuality"
                    Stretch="UniformToFill"
                    IsVisible="{CompiledBinding CoverBitMap, Converter={x:Static ObjectConverters.IsNotNull}}"/>

                <!-- Missing Cover Fallback -->
                <StackPanel
                    IsVisible="{CompiledBinding CoverBitMap, Converter={x:Static ObjectConverters.IsNull}}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="10">
                  <PathIcon
                      Data="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"
                      Width="48" Height="48"
                      Foreground="{DynamicResource TsundokuStatusAndBookTypeTextColor}"
                      Opacity="0.3"/>
                  <TextBlock
                      TextAlignment="Center"
                      MaxLines="4"
                      TextTrimming="CharacterEllipsis"
                      FontWeight="Bold"
                      FontSize="13"
                      Foreground="{DynamicResource TsundokuStatusAndBookTypeTextColor}"
                      Opacity="0.5"
                      Width="{CompiledBinding Source={x:Static m:Constants.LEFT_SIDE_CARD_WIDTH}}"
                      Padding="8,0">
                    <TextBlock.Text>
                      <MultiBinding Converter="{StaticResource ConvertTitle}" Mode="OneWay">
                        <Binding Path="Titles"/>
                        <Binding Path="Language" ElementName="Root"/>
                      </MultiBinding>
                    </TextBlock.Text>
                  </TextBlock>
                </StackPanel>

                <!-- Status/Format Badge Overlay (glassmorphic) -->
                <Border
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,8"
                    Background="{DynamicResource TsundokuStatusAndBookTypeBGColor}"
                    BorderBrush="{DynamicResource TsundokuStatusAndBookTypeBorderColor}"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="10,4"
                    Opacity="0.92"
                    BoxShadow="0 2 8 0 #40000000">
                  <TextBlock
                      FontSize="11"
                      FontWeight="Bold"
                      Foreground="{DynamicResource TsundokuStatusAndBookTypeTextColor}"
                      TextAlignment="Center">
                    <TextBlock.Text>
                      <MultiBinding StringFormat="{}{0} · {1}" Mode="OneWay">
                        <Binding Path="Status"/>
                        <Binding Path="Format"/>
                      </MultiBinding>
                    </TextBlock.Text>
                  </TextBlock>
                </Border>
              </Panel>

              <!-- ── Right Side: Info + Progress ── -->
              <Panel Grid.Column="1" UseLayoutRounding="True">
                <!-- Solid fallback background -->
                <Border Name="CardSolidBG" Background="{DynamicResource TsundokuSeriesCardBGColor}"/>
                <!-- Glassmorphism acrylic overlay -->
                <ExperimentalAcrylicBorder
                    Name="CardAcrylicBorder"
                    IsVisible="False">
                  <ExperimentalAcrylicBorder.Material>
                    <ExperimentalAcrylicMaterial
                        BackgroundSource="Digger"
                        TintColor="#1A1A2E"
                        TintOpacity="0.75"
                        MaterialOpacity="0.6"/>
                  </ExperimentalAcrylicBorder.Material>
                </ExperimentalAcrylicBorder>
                <Grid>
                <Grid RowDefinitions="*,Auto">

                  <!-- Info Section -->
                  <Grid
                      Grid.Row="0"
                      RowDefinitions="Auto,Auto,Auto,*"
                      Margin="10,4,10,0">

                    <!-- Publisher -->
                    <TextBlock
                        Grid.Row="0"
                        Foreground="{DynamicResource TsundokuSeriesCardPublisherColor}"
                        MaxLines="1"
                        FontWeight="SemiBold"
                        FontSize="12"
                        Text="{CompiledBinding Publisher}"
                        IsHitTestVisible="False"
                        Padding="0"/>

                    <!-- Series Title -->
                    <TextBlock
                        Grid.Row="1"
                        x:Name="SeriesTitleTextBlock"
                        TextWrapping="Wrap"
                        Foreground="{DynamicResource TsundokuSeriesCardTitleColor}"
                        FontWeight="Bold"
                        FontSize="22"
                        PointerPressed="CopySeriesTitleAsync"
                        Cursor="Hand"
                        TextAlignment="Left"
                        TextTrimming="CharacterEllipsis"
                        MaxLines="2"
                        Padding="0,0,4,0">
                      <TextBlock.Text>
                        <MultiBinding Converter="{StaticResource ConvertTitle}" Mode="OneWay">
                          <Binding Path="Titles"/>
                          <Binding Path="Language" ElementName="Root"/>
                        </MultiBinding>
                      </TextBlock.Text>
                      <ToolTip.Tip>
                        <TextBlock FontWeight="Bold" TextWrapping="Wrap" FontSize="18" TextTrimming="None" MaxLines="100" LineSpacing="2">
                          <TextBlock.Text>
                            <MultiBinding Converter="{StaticResource ConvertTitle}" Mode="OneWay">
                              <Binding Path="Titles"/>
                              <Binding Path="Language" ElementName="Root"/>
                              <Binding Path="DuplicateIndex"/>
                            </MultiBinding>
                          </TextBlock.Text>
                        </TextBlock>
                      </ToolTip.Tip>
                    </TextBlock>

                    <!-- Staff -->
                    <TextBlock
                        Grid.Row="2"
                        TextWrapping="Wrap"
                        FontWeight="Bold"
                        Foreground="{DynamicResource TsundokuSeriesCardStaffColor}"
                        MaxLines="1"
                        TextTrimming="CharacterEllipsis"
                        FontSize="13"
                        Padding="0,0,4,4">
                      <TextBlock.Text>
                        <MultiBinding Converter="{StaticResource ConvertStaff}" Mode="OneWay">
                          <Binding Path="Staff"/>
                          <Binding Path="#Root.Language"/>
                        </MultiBinding>
                      </TextBlock.Text>
                      <ToolTip.Tip>
                        <TextBlock TextWrapping="Wrap" FontWeight="Bold" TextTrimming="None" MaxLines="100">
                          <TextBlock.Text>
                            <MultiBinding Converter="{StaticResource ConvertStaff}" Mode="OneWay">
                              <Binding Path="Staff"/>
                              <Binding Path="#Root.Language"/>
                            </MultiBinding>
                          </TextBlock.Text>
                        </TextBlock>
                      </ToolTip.Tip>
                    </TextBlock>

                    <!-- Description -->
                    <ScrollViewer
                        Classes="card-desc"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        Grid.Row="3">
                      <TextBlock
                          TextWrapping="Wrap"
                          FontSize="12"
                          FontWeight="SemiBold"
                          Foreground="{DynamicResource TsundokuSeriesCardDescColor}"
                          Opacity="0.9"
                          Text="{CompiledBinding Description}"
                          Padding="0,0,10,0"/>
                    </ScrollViewer>
                  </Grid>

                  <!-- Progress Footer -->
                  <Border Grid.Row="1" BorderThickness="0,2,0,0" BorderBrush="{DynamicResource TsundokuSeriesCardDividerColor}" Margin="8,0,8,0" Padding="0,6,0,6">
                  <Grid
                      ColumnDefinitions="Auto,Auto,*,Auto">
                    <!-- - Button -->
                    <Button Grid.Column="0" Theme="{StaticResource SeriesCardButton}" Content="&#x2212;" Margin="0,0,4,0" Click="SubtractVolume"/>

                    <!-- + Button -->
                    <Button Grid.Column="1" Theme="{StaticResource SeriesCardButton}" Content="+" Margin="0,0,8,0" Click="AddVolume"/>

                    <!-- Progress Bar with overlay text -->
                    <Panel Grid.Column="2">
                      <ProgressBar
                          Height="28"
                          Value="{CompiledBinding CurVolumeCount}"
                          Background="{DynamicResource TsundokuSeriesProgressBarBGColor}"
                          Foreground="{DynamicResource TsundokuSeriesProgressBarColor}"
                          BorderBrush="{DynamicResource TsundokuSeriesProgressBarBorderColor}"
                          BorderThickness="2"
                          CornerRadius="6"
                          Padding="3"
                          Minimum="0"
                          Maximum="{CompiledBinding MaxVolumeCount}"/>
                      <TextBlock
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Margin="0,1,0,0"
                          FontSize="13"
                          FontWeight="Bold"
                          Foreground="{DynamicResource TsundokuSeriesProgressTextColor}"
                          IsHitTestVisible="False">
                        <TextBlock.Text>
                          <MultiBinding StringFormat="{}{0} / {1}" Mode="OneWay">
                            <Binding Path="CurVolumeCount"/>
                            <Binding Path="MaxVolumeCount"/>
                          </MultiBinding>
                        </TextBlock.Text>
                      </TextBlock>
                    </Panel>

                    <!-- Edit Button -->
                    <Button
                        Grid.Column="3"
                        Theme="{StaticResource SeriesCardButton}"
                        Margin="8,0,0,0"
                        i:Attached.Icon="fa-solid fa-pen"
                        FontSize="14"
                        Click="OpenEditSeriesInfoWindow"/>
                  </Grid>
                  </Border>
                </Grid>
              </Grid>
              </Panel>
            </Grid>
          </Border>
        </Border>

      </DataTemplate>
    </ContentControl.ContentTemplate>
  </ContentControl>
</UserControl>