<Window xmlns="https://github.com/avaloniaui"
		xmlns:vm="using:Tsundoku.ViewModels"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:controls="clr-namespace:Tsundoku.Controls"
		xmlns:charts="clr-namespace:Tsundoku.Views"
		xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
		xmlns:i="clr-namespace:Projektanker.Icons.Avalonia;assembly=Projektanker.Icons.Avalonia"
        x:Class="Tsundoku.Views.CollectionStatsWindow"
		x:DataType="vm:CollectionStatsViewModel"
		Icon="\Assets\Icons\TsundokuLogo.ico"
        Title="Stats"
        Classes="Menu"
		WindowStartupLocation="CenterOwner"
        MinWidth="700"
		MaxWidth="1100"
		MaxHeight="1700"
		CanResize="true">

	<Window.Styles>
		<StyleInclude Source="/Controls/ValueStat.axaml"/>
	</Window.Styles>

	<Border Classes="Menu" BorderThickness="2" CornerRadius="0,0,8,8" ClipToBounds="True">
		<Grid RowDefinitions="Auto,*">
			<!-- Header -->
			<Border Grid.Row="0" BorderThickness="0,0,0,2" BorderBrush="{DynamicResource TsundokuDividerColor}" Padding="16,12">
				<StackPanel Orientation="Horizontal" Spacing="8">
					<i:Icon Value="fa-solid fa-chart-simple" FontSize="16" Foreground="{DynamicResource TsundokuDividerColor}"/>
					<TextBlock Text="Collection Stats" FontSize="18" FontWeight="ExtraBold" Foreground="{DynamicResource TsundokuUsernameColor}" VerticalAlignment="Center"/>
				</StackPanel>
			</Border>

		<ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Theme="{StaticResource ReverseCollectionScroll}">
			<StackPanel Spacing="0" Margin="16,14,16,16">

				<!-- OVERVIEW STATS (3 per row) -->
				<TextBlock Text="OVERVIEW" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TsundokuSeriesCardPublisherColor}" LetterSpacing="1" Opacity="0.8" Margin="0,0,0,8"/>
				<UniformGrid Columns="3">
					<controls:ValueStat Text="{CompiledBinding CurrentUser.MeanRating}" Title="Mean Rating" PointerPressed="CopyTextAsync"/>
					<controls:ValueStat Text="{CompiledBinding CurrentUser.VolumesRead}" Title="Volumes Read" PointerPressed="CopyTextAsync"/>
					<controls:ValueStat Text="{CompiledBinding SeriesCount}" Title="Series Count" PointerPressed="CopyTextAsync"/>
					<controls:ValueStat Text="{CompiledBinding CurrentUser.NumVolumesCollected}" Title="Volumes Collected" PointerPressed="CopyTextAsync"/>
					<controls:ValueStat Text="{CompiledBinding CurrentUser.NumVolumesToBeCollected}" Title="Volumes To Be Collected" PointerPressed="CopyTextAsync"/>
					<controls:ValueStat Text="{CompiledBinding CurrentUser.CollectionValue}" Title="Collection Value" PointerPressed="CopyTextAsync"/>
				</UniformGrid>

				<!-- DISTRIBUTIONS (3 pie charts in a row, legend below each chart) -->
				<Border BorderThickness="0,2,0,0" BorderBrush="{DynamicResource TsundokuDividerColor}" Opacity="0.3" Margin="0,12,0,0"/>
				<TextBlock Text="DISTRIBUTIONS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TsundokuSeriesCardPublisherColor}" LetterSpacing="1" Opacity="0.8" Margin="0,12,0,8"/>
				<UniformGrid Columns="3">
					<!-- Demographic -->
					<Border Background="{DynamicResource TsundokuMenuButtonBGColor}"
							BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}"
							BorderThickness="2" CornerRadius="10" Margin="4" Padding="6,4">
						<StackPanel Spacing="0" HorizontalAlignment="Center">
							<TextBlock Text="Demographic" FontSize="14" FontWeight="ExtraBold" Foreground="{DynamicResource TsundokuUsernameColor}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
							<lvc:PieChart Series="{CompiledBinding Demographics}" Width="200" Height="200" TooltipPosition="Hidden" Margin="0,-4"/>
							<WrapPanel HorizontalAlignment="Center">
								<StackPanel Orientation="Horizontal" Spacing="4" Margin="4,2">
									<Border CornerRadius="3" Width="16" Height="16" Background="{DynamicResource TsundokuMenuBGColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="1.5"/>
									<TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TsundokuMenuTextColor}" VerticalAlignment="Center">
										<TextBlock.Text>
											<MultiBinding StringFormat="Shounen {0}%" Mode="OneWay">
												<Binding Path="ShounenPercentage"/>
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</StackPanel>
								<StackPanel Orientation="Horizontal" Spacing="4" Margin="4,2">
									<Border CornerRadius="3" Width="16" Height="16" Background="{DynamicResource TsundokuMenuTextColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="1.5"/>
									<TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TsundokuMenuTextColor}" VerticalAlignment="Center">
										<TextBlock.Text>
											<MultiBinding StringFormat="Shoujo {0}%" Mode="OneWay">
												<Binding Path="ShoujoPercentage"/>
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</StackPanel>
								<StackPanel Orientation="Horizontal" Spacing="4" Margin="4,2">
									<Border CornerRadius="3" Width="16" Height="16" Background="{DynamicResource TsundokuMenuButtonBGColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="1.5"/>
									<TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TsundokuMenuTextColor}" VerticalAlignment="Center">
										<TextBlock.Text>
											<MultiBinding StringFormat="Seinen {0}%" Mode="OneWay">
												<Binding Path="SeinenPercentage"/>
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</StackPanel>
								<StackPanel Orientation="Horizontal" Spacing="4" Margin="4,2">
									<Border CornerRadius="3" Width="16" Height="16" Background="{DynamicResource TsundokuDividerColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="1.5"/>
									<TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TsundokuMenuTextColor}" VerticalAlignment="Center">
										<TextBlock.Text>
											<MultiBinding StringFormat="Josei {0}%" Mode="OneWay">
												<Binding Path="JoseiPercentage"/>
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</StackPanel>
								<StackPanel Orientation="Horizontal" Spacing="4" Margin="4,2">
									<Border CornerRadius="3" Width="16" Height="16" Background="{CompiledBinding UnknownRectangleColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="1.5"/>
									<TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TsundokuMenuTextColor}" VerticalAlignment="Center">
										<TextBlock.Text>
											<MultiBinding StringFormat="Unknown {0}%" Mode="OneWay">
												<Binding Path="UnknownPercentage"/>
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</StackPanel>
							</WrapPanel>
						</StackPanel>
					</Border>

					<!-- Status -->
					<Border Background="{DynamicResource TsundokuMenuButtonBGColor}"
							BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}"
							BorderThickness="2" CornerRadius="10" Margin="4" Padding="6,4">
						<StackPanel Spacing="0" HorizontalAlignment="Center">
							<TextBlock Text="Status" FontSize="14" FontWeight="ExtraBold" Foreground="{DynamicResource TsundokuUsernameColor}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
							<lvc:PieChart Series="{CompiledBinding StatusDistribution}" Width="200" Height="200" TooltipPosition="Hidden" Margin="0,-4"/>
							<WrapPanel HorizontalAlignment="Center">
								<StackPanel Orientation="Horizontal" Spacing="4" Margin="4,2">
									<Border CornerRadius="3" Width="16" Height="16" Background="{DynamicResource TsundokuMenuButtonBGColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="1.5"/>
									<TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TsundokuMenuTextColor}" VerticalAlignment="Center">
										<TextBlock.Text>
											<MultiBinding StringFormat="Finished {0}%" Mode="OneWay">
												<Binding Path="FinishedPercentage"/>
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</StackPanel>
								<StackPanel Orientation="Horizontal" Spacing="4" Margin="4,2">
									<Border CornerRadius="3" Width="16" Height="16" Background="{DynamicResource TsundokuMenuBGColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="1.5"/>
									<TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TsundokuMenuTextColor}" VerticalAlignment="Center">
										<TextBlock.Text>
											<MultiBinding StringFormat="Ongoing {0}%" Mode="OneWay">
												<Binding Path="OngoingPercentage"/>
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</StackPanel>
								<StackPanel Orientation="Horizontal" Spacing="4" Margin="4,2">
									<Border CornerRadius="3" Width="16" Height="16" Background="{DynamicResource TsundokuMenuTextColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="1.5"/>
									<TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TsundokuMenuTextColor}" VerticalAlignment="Center">
										<TextBlock.Text>
											<MultiBinding StringFormat="Hiatus {0}%" Mode="OneWay">
												<Binding Path="HiatusPercentage"/>
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</StackPanel>
								<StackPanel Orientation="Horizontal" Spacing="4" Margin="4,2">
									<Border CornerRadius="3" Width="16" Height="16" Background="{DynamicResource TsundokuDividerColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="1.5"/>
									<TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TsundokuMenuTextColor}" VerticalAlignment="Center">
										<TextBlock.Text>
											<MultiBinding StringFormat="Cancelled {0}%" Mode="OneWay">
												<Binding Path="CancelledPercentage"/>
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</StackPanel>
							</WrapPanel>
						</StackPanel>
					</Border>

					<!-- Format -->
					<Border Background="{DynamicResource TsundokuMenuButtonBGColor}"
							BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}"
							BorderThickness="2" CornerRadius="10" Margin="4" Padding="6,4">
						<StackPanel Spacing="0" HorizontalAlignment="Center">
							<TextBlock Text="Format" FontSize="14" FontWeight="ExtraBold" Foreground="{DynamicResource TsundokuUsernameColor}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
							<lvc:PieChart Series="{CompiledBinding Formats}" Width="200" Height="200" TooltipPosition="Hidden" Margin="0,-4"/>
							<WrapPanel HorizontalAlignment="Center">
								<StackPanel Orientation="Horizontal" Spacing="4" Margin="4,2">
									<Border CornerRadius="3" Width="16" Height="16" Background="{DynamicResource TsundokuMenuButtonBGColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="1.5"/>
									<TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TsundokuMenuTextColor}" VerticalAlignment="Center">
										<TextBlock.Text>
											<MultiBinding StringFormat="Manga {0}%" Mode="OneWay">
												<Binding Path="MangaPercentage"/>
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</StackPanel>
								<StackPanel Orientation="Horizontal" Spacing="4" Margin="4,2">
									<Border CornerRadius="3" Width="16" Height="16" Background="{DynamicResource TsundokuMenuBGColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="1.5"/>
									<TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TsundokuMenuTextColor}" VerticalAlignment="Center">
										<TextBlock.Text>
											<MultiBinding StringFormat="Manhwa {0}%" Mode="OneWay">
												<Binding Path="ManhwaPercentage"/>
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</StackPanel>
								<StackPanel Orientation="Horizontal" Spacing="4" Margin="4,2">
									<Border CornerRadius="3" Width="16" Height="16" Background="{DynamicResource TsundokuMenuTextColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="1.5"/>
									<TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TsundokuMenuTextColor}" VerticalAlignment="Center">
										<TextBlock.Text>
											<MultiBinding StringFormat="Novel {0}%" Mode="OneWay">
												<Binding Path="NovelPercentage"/>
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</StackPanel>
								<StackPanel Orientation="Horizontal" Spacing="4" Margin="4,2">
									<Border CornerRadius="3" Width="16" Height="16" Background="{DynamicResource TsundokuDividerColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="1.5"/>
									<TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TsundokuMenuTextColor}" VerticalAlignment="Center">
										<TextBlock.Text>
											<MultiBinding StringFormat="Comic {0}%" Mode="OneWay">
												<Binding Path="ComicPercentage"/>
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</StackPanel>
								<StackPanel Orientation="Horizontal" Spacing="4" Margin="4,2">
									<Border CornerRadius="3" Width="16" Height="16" Background="{CompiledBinding ManhuaRectangleColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="1.5"/>
									<TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TsundokuMenuTextColor}" VerticalAlignment="Center">
										<TextBlock.Text>
											<MultiBinding StringFormat="Manhua {0}%" Mode="OneWay">
												<Binding Path="ManhuaPercentage"/>
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</StackPanel>
								<StackPanel Orientation="Horizontal" Spacing="4" Margin="4,2">
									<Border CornerRadius="3" Width="16" Height="16" Background="{CompiledBinding ManfraRectangleColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="1.5"/>
									<TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TsundokuMenuTextColor}" VerticalAlignment="Center">
										<TextBlock.Text>
											<MultiBinding StringFormat="Manfra {0}%" Mode="OneWay">
												<Binding Path="ManfraPercentage"/>
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</StackPanel>
							</WrapPanel>
						</StackPanel>
					</Border>
				</UniformGrid>

				<!-- BAR CHARTS (2 per row) -->
				<Border BorderThickness="0,2,0,0" BorderBrush="{DynamicResource TsundokuDividerColor}" Opacity="0.3" Margin="0,12,0,0"/>
				<TextBlock Text="CHARTS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TsundokuSeriesCardPublisherColor}" LetterSpacing="1" Opacity="0.8" Margin="0,12,0,8"/>
				<UniformGrid Columns="2">
					<!-- Rating Bar Chart -->
					<Border Background="{DynamicResource TsundokuMenuButtonBGColor}"
							BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}"
							BorderThickness="2" CornerRadius="10" Margin="4" Padding="10">
						<StackPanel>
							<TextBlock Text="Ratings" FontSize="14" FontWeight="ExtraBold" Foreground="{DynamicResource TsundokuUsernameColor}" Margin="0,0,0,4"/>
							<lvc:CartesianChart
								Series="{CompiledBinding RatingDistribution}"
								XAxes="{CompiledBinding RatingXAxes}"
								YAxes="{CompiledBinding RatingYAxes}"
								Height="240"/>
						</StackPanel>
					</Border>

					<!-- Volume Count Bar Chart -->
					<Border Background="{DynamicResource TsundokuMenuButtonBGColor}"
							BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}"
							BorderThickness="2" CornerRadius="10" Margin="4" Padding="10">
						<StackPanel>
							<TextBlock Text="Volume Counts" FontSize="14" FontWeight="ExtraBold" Foreground="{DynamicResource TsundokuUsernameColor}" Margin="0,0,0,4"/>
							<lvc:CartesianChart
								Series="{CompiledBinding VolumeCountDistribution}"
								XAxes="{CompiledBinding VolumeCountXAxes}"
								YAxes="{CompiledBinding VolumeCountYAxes}"
								Height="240"/>
						</StackPanel>
					</Border>

					<!-- Genre Bar Chart (Left Half) -->
					<Border Background="{DynamicResource TsundokuMenuButtonBGColor}"
							BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}"
							BorderThickness="2" CornerRadius="10" Margin="4" Padding="10">
						<StackPanel>
							<TextBlock Text="Genres (1/2)" FontSize="14" FontWeight="ExtraBold" Foreground="{DynamicResource TsundokuUsernameColor}" Margin="0,0,0,4"/>
							<lvc:CartesianChart
								Series="{CompiledBinding GenreDistribution1}"
								XAxes="{CompiledBinding GenreXAxes1}"
								YAxes="{CompiledBinding GenreYAxes1}"
								Height="240"/>
						</StackPanel>
					</Border>

					<!-- Genre Bar Chart (Right Half) -->
					<Border Background="{DynamicResource TsundokuMenuButtonBGColor}"
							BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}"
							BorderThickness="2" CornerRadius="10" Margin="4" Padding="10">
						<StackPanel>
							<TextBlock Text="Genres (2/2)" FontSize="14" FontWeight="ExtraBold" Foreground="{DynamicResource TsundokuUsernameColor}" Margin="0,0,0,4"/>
							<lvc:CartesianChart
								Series="{CompiledBinding GenreDistribution2}"
								XAxes="{CompiledBinding GenreXAxes2}"
								YAxes="{CompiledBinding GenreYAxes2}"
								Height="240"/>
						</StackPanel>
					</Border>
				</UniformGrid>
			</StackPanel>
		</ScrollViewer>
		</Grid>
	</Border>
</Window>
