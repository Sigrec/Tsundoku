<Window xmlns="https://github.com/avaloniaui"
		xmlns:vm="using:Tsundoku.ViewModels"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:controls="clr-namespace:Tsundoku.Controls"
		xmlns:charts="clr-namespace:Tsundoku.Views"
		xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
		xmlns:i="clr-namespace:Projektanker.Icons.Avalonia;assembly=Projektanker.Icons.Avalonia"
        x:Class="Tsundoku.Views.CollectionStatsWindow"
		x:DataType="vm:CollectionStatsViewModel"
		Icon="\Assets\Icons\TsundokuLogo.ico"
        Title="Stats"
        Classes="Menu"
		WindowStartupLocation="CenterOwner"
		SizeToContent="Height"
        MinWidth="700"
		MaxWidth="1050"
		CanResize="true">

	<Window.Styles>
		<StyleInclude Source="/Controls/ValueStat.axaml"/>
		<StyleInclude Source="/Controls/ChartLegendItem.axaml"/>
	</Window.Styles>

	<Border Classes="Menu" BorderThickness="2" CornerRadius="0,0,8,8" ClipToBounds="True">
		<Grid RowDefinitions="Auto,*">
			<!-- Header -->
			<Border Grid.Row="0" BorderThickness="0,0,0,2" BorderBrush="{DynamicResource TsundokuDividerColor}" Padding="16,12">
				<StackPanel Orientation="Horizontal" Spacing="8">
					<i:Icon Value="fa-solid fa-chart-simple" FontSize="16" Foreground="{DynamicResource TsundokuDividerColor}"/>
					<TextBlock Text="Collection Stats" FontSize="18" FontWeight="ExtraBold" Foreground="{DynamicResource TsundokuUsernameColor}" VerticalAlignment="Center"/>
				</StackPanel>
			</Border>

		<ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden" Theme="{StaticResource ReverseCollectionScroll}">
			<StackPanel Spacing="0" Margin="16,14,16,16" HorizontalAlignment="Center" VerticalAlignment="Center">

				<!-- OVERVIEW STATS (3 per row) -->
				<TextBlock Text="OVERVIEW" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TsundokuSeriesCardPublisherColor}" LetterSpacing="1" Opacity="0.8" Margin="4,0,0,8"/>
				<WrapPanel HorizontalAlignment="Center">
					<controls:ValueStat Text="{Binding CurrentUser.MeanRating}" Title="Mean Rating" PointerPressed="CopyTextAsync"/>
					<controls:ValueStat Text="{Binding CurrentUser.VolumesRead, StringFormat='{}{0:N0}'}" Title="Volumes Read" PointerPressed="CopyTextAsync"/>
					<controls:ValueStat Text="{Binding SeriesCount, StringFormat='{}{0:N0}'}" Title="Series Count" PointerPressed="CopyTextAsync"/>
					<controls:ValueStat Text="{Binding CurrentUser.NumVolumesCollected, StringFormat='{}{0:N0}'}" Title="Volumes Collected" PointerPressed="CopyTextAsync"/>
					<controls:ValueStat Text="{Binding CurrentUser.NumVolumesToBeCollected, StringFormat='{}{0:N0}'}" Title="Volumes To Be Collected" PointerPressed="CopyTextAsync"/>
					<controls:ValueStat Text="{Binding FavoriteCount, StringFormat='{}{0:N0}'}" Title="Favorites" PointerPressed="CopyTextAsync"/>
					<controls:ValueStat Text="{Binding FullyCollectedCount, StringFormat='{}{0:N0}'}" Title="Fully Collected" PointerPressed="CopyTextAsync"/>
					<controls:ValueStat Text="{Binding CompletionRate}" Title="Completion Rate" PointerPressed="CopyTextAsync"/>
				</WrapPanel>
				<controls:ValueStat Text="{Binding CurrentUser.CollectionValue}" Title="Collection Value" Width="NaN" MinWidth="480" MaxWidth="976" HorizontalAlignment="Center" Margin="4,4,4,0" PointerPressed="CopyTextAsync"/>

				<!-- DISTRIBUTIONS (3 pie charts in a row, legend below each chart) -->
				<Border BorderThickness="0,2,0,0" BorderBrush="{DynamicResource TsundokuDividerColor}" Opacity="0.3" Margin="0,12,0,0"/>
				<TextBlock Text="DISTRIBUTIONS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TsundokuSeriesCardPublisherColor}" LetterSpacing="1" Opacity="0.8" Margin="4,12,0,8"/>
				<WrapPanel HorizontalAlignment="Center">
					<!-- Demographic -->
					<Border Background="{DynamicResource TsundokuMenuButtonBGColor}"
							BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}"
							BorderThickness="2" CornerRadius="10" Margin="4" Padding="12" Width="317">
						<StackPanel Spacing="0" HorizontalAlignment="Center">
							<TextBlock Text="Demographic" FontSize="14" FontWeight="ExtraBold" Foreground="{DynamicResource TsundokuUsernameColor}" HorizontalAlignment="Center" Margin="0,2,0,5"/>
							<Border BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="1.5" CornerRadius="100" Padding="4" Margin="0,4">
								<lvc:PieChart Series="{CompiledBinding Demographics}" Width="190" Height="190" TooltipPosition="Hidden"/>
							</Border>
							<StackPanel Spacing="0" HorizontalAlignment="Stretch" Margin="2,0">
								<controls:ChartLegendItem Label="Shounen" Percentage="{CompiledBinding ShounenPercentage}" Color="{CompiledBinding ShounenLegendColor}"/>
								<controls:ChartLegendItem Label="Seinen" Percentage="{CompiledBinding SeinenPercentage}" Color="{CompiledBinding SeinenLegendColor}"/>
								<controls:ChartLegendItem Label="Shoujo" Percentage="{CompiledBinding ShoujoPercentage}" Color="{CompiledBinding ShoujoLegendColor}"/>
								<controls:ChartLegendItem Label="Josei" Percentage="{CompiledBinding JoseiPercentage}" Color="{CompiledBinding JoseiLegendColor}"/>
								<controls:ChartLegendItem Label="Unknown" Percentage="{CompiledBinding UnknownPercentage}" Color="{CompiledBinding UnknownLegendColor}"/>
							</StackPanel>
						</StackPanel>
					</Border>

					<!-- Status -->
					<Border Background="{DynamicResource TsundokuMenuButtonBGColor}"
							BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}"
							BorderThickness="2" CornerRadius="10" Margin="4" Padding="12" Width="317">
						<StackPanel Spacing="0" HorizontalAlignment="Center">
							<TextBlock Text="Status" FontSize="14" FontWeight="ExtraBold" Foreground="{DynamicResource TsundokuUsernameColor}" HorizontalAlignment="Center" Margin="0,2,0,5"/>
							<Border BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="1.5" CornerRadius="100" Padding="4" Margin="0,4">
								<lvc:PieChart Series="{CompiledBinding StatusDistribution}" Width="190" Height="190" TooltipPosition="Hidden"/>
							</Border>
							<StackPanel Spacing="0" HorizontalAlignment="Stretch" Margin="2,0">
								<controls:ChartLegendItem Label="Finished" Percentage="{CompiledBinding FinishedPercentage}" Color="{CompiledBinding FinishedLegendColor}"/>
								<controls:ChartLegendItem Label="Ongoing" Percentage="{CompiledBinding OngoingPercentage}" Color="{CompiledBinding OngoingLegendColor}"/>
								<controls:ChartLegendItem Label="Hiatus" Percentage="{CompiledBinding HiatusPercentage}" Color="{CompiledBinding HiatusLegendColor}"/>
								<controls:ChartLegendItem Label="Cancelled" Percentage="{CompiledBinding CancelledPercentage}" Color="{CompiledBinding CancelledLegendColor}"/>
							</StackPanel>
						</StackPanel>
					</Border>

					<!-- Format -->
					<Border Background="{DynamicResource TsundokuMenuButtonBGColor}"
							BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}"
							BorderThickness="2" CornerRadius="10" Margin="4" Padding="12" Width="317">
						<StackPanel Spacing="0" HorizontalAlignment="Center">
							<TextBlock Text="Format" FontSize="14" FontWeight="ExtraBold" Foreground="{DynamicResource TsundokuUsernameColor}" HorizontalAlignment="Center" Margin="0,2,0,5"/>
							<Border BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="1.5" CornerRadius="100" Padding="4" Margin="0,4">
								<lvc:PieChart Series="{CompiledBinding Formats}" Width="190" Height="190" TooltipPosition="Hidden"/>
							</Border>
							<StackPanel Spacing="0" HorizontalAlignment="Stretch" Margin="2,0">
								<controls:ChartLegendItem Label="Manga" Percentage="{CompiledBinding MangaPercentage}" Color="{CompiledBinding MangaLegendColor}"/>
								<controls:ChartLegendItem Label="Manhwa" Percentage="{CompiledBinding ManhwaPercentage}" Color="{CompiledBinding ManhwaLegendColor}"/>
								<controls:ChartLegendItem Label="Novel" Percentage="{CompiledBinding NovelPercentage}" Color="{CompiledBinding NovelLegendColor}"/>
								<controls:ChartLegendItem Label="Comic" Percentage="{CompiledBinding ComicPercentage}" Color="{CompiledBinding ComicLegendColor}"/>
								<controls:ChartLegendItem Label="Manhua" Percentage="{CompiledBinding ManhuaPercentage}" Color="{CompiledBinding ManhuaLegendColor}"/>
								<controls:ChartLegendItem Label="Manfra" Percentage="{CompiledBinding ManfraPercentage}" Color="{CompiledBinding ManfraLegendColor}"/>
							</StackPanel>
						</StackPanel>
					</Border>
				</WrapPanel>

				<!-- BAR CHARTS (2 per row) -->
				<Border BorderThickness="0,2,0,0" BorderBrush="{DynamicResource TsundokuDividerColor}" Opacity="0.3" Margin="0,12,0,0"/>
				<TextBlock Text="CHARTS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TsundokuSeriesCardPublisherColor}" LetterSpacing="1" Opacity="0.8" Margin="4,12,0,8"/>
				<WrapPanel HorizontalAlignment="Center">
					<!-- Rating Bar Chart -->
					<Border Background="{DynamicResource TsundokuMenuButtonBGColor}"
							BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}"
							BorderThickness="2" CornerRadius="10" Margin="4" Padding="10" Width="480">
						<StackPanel>
							<TextBlock Text="Ratings" FontSize="14" FontWeight="ExtraBold" Foreground="{DynamicResource TsundokuUsernameColor}" Margin="0,0,0,4"/>
							<lvc:CartesianChart
								ZoomMode="None"
								Series="{CompiledBinding RatingDistribution}"
								XAxes="{CompiledBinding RatingXAxes}"
								YAxes="{CompiledBinding RatingYAxes}"
								Height="290"/>
						</StackPanel>
					</Border>

					<!-- Volume Count Bar Chart -->
					<Border Background="{DynamicResource TsundokuMenuButtonBGColor}"
							BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}"
							BorderThickness="2" CornerRadius="10" Margin="4" Padding="10" Width="480">
						<StackPanel>
							<TextBlock Text="Volume Counts" FontSize="14" FontWeight="ExtraBold" Foreground="{DynamicResource TsundokuUsernameColor}" Margin="0,0,0,4"/>
							<lvc:CartesianChart
								ZoomMode="None"
								Series="{CompiledBinding VolumeCountDistribution}"
								XAxes="{CompiledBinding VolumeCountXAxes}"
								YAxes="{CompiledBinding VolumeCountYAxes}"
								Height="290"/>
						</StackPanel>
					</Border>

					<!-- Genre Bar Chart (Left Half) -->
					<Border Background="{DynamicResource TsundokuMenuButtonBGColor}"
							BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}"
							BorderThickness="2" CornerRadius="10" Margin="4" Padding="10" Width="480">
						<StackPanel>
							<TextBlock Text="Genres (1/2)" FontSize="14" FontWeight="ExtraBold" Foreground="{DynamicResource TsundokuUsernameColor}" Margin="0,0,0,4"/>
							<lvc:CartesianChart
								ZoomMode="None"
								Series="{CompiledBinding GenreDistribution1}"
								XAxes="{CompiledBinding GenreXAxes1}"
								YAxes="{CompiledBinding GenreYAxes1}"
								Height="290"/>
						</StackPanel>
					</Border>

					<!-- Genre Bar Chart (Right Half) -->
					<Border Background="{DynamicResource TsundokuMenuButtonBGColor}"
							BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}"
							BorderThickness="2" CornerRadius="10" Margin="4" Padding="10" Width="480">
						<StackPanel>
							<TextBlock Text="Genres (2/2)" FontSize="14" FontWeight="ExtraBold" Foreground="{DynamicResource TsundokuUsernameColor}" Margin="0,0,0,4"/>
							<lvc:CartesianChart
								ZoomMode="None"
								Series="{CompiledBinding GenreDistribution2}"
								XAxes="{CompiledBinding GenreXAxes2}"
								YAxes="{CompiledBinding GenreYAxes2}"
								Height="290"/>
						</StackPanel>
					</Border>
				</WrapPanel>
			</StackPanel>
		</ScrollViewer>
		</Grid>
	</Border>
</Window>
