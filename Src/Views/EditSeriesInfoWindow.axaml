<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="clr-namespace:Optris.Icons.Avalonia;assembly=Optris.Icons.Avalonia"
        xmlns:vm="clr-namespace:Tsundoku.ViewModels"
        xmlns:enums="clr-namespace:Tsundoku.Models.Enums"
        x:Class="Tsundoku.Views.EditSeriesInfoWindow"
        x:DataType="vm:EditSeriesInfoViewModel"
        Classes="Menu"
        WindowStartupLocation="CenterScreen"
        SizeToContent="WidthAndHeight"
        CanResize="false">

    <Border Classes="Menu" BorderThickness="2" CornerRadius="0,0,8,8" ClipToBounds="True">
        <Grid RowDefinitions="Auto,*">
            <!-- Header -->
            <Border Grid.Row="0" BorderThickness="0,0,0,2" BorderBrush="{DynamicResource TsundokuDividerColor}" Padding="16,12">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="8" ClipToBounds="True">
                        <i:Icon Value="fa7-solid fa7-pen-to-square" FontSize="16" Foreground="{DynamicResource TsundokuDividerColor}"/>
                        <TextBlock FontSize="18" FontWeight="ExtraBold" Foreground="{DynamicResource TsundokuUsernameColor}" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Edit Series — {0}">
                                    <Binding Path="Title" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                    <Button Grid.Column="1"
                            x:Name="DeleteSeriesButton"
                            i:Attached.Icon="fa7-solid fa7-trash-can"
                            FontSize="14" Width="34" Height="34"
                            Theme="{StaticResource MenuButton}"
                            ToolTip.Tip="Delete Series"
                            Click="RemoveSeries"/>
                </Grid>
            </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,12,200" Margin="16,14,16,16">
                <!-- LEFT COLUMN -->
                <StackPanel Grid.Column="0" Spacing="12">
                    <!-- Series Notes -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="SERIES NOTES" Classes="section-title"/>
                        <TextBox x:Name="SeriesNotesTextBox"
                                 Height="160"
                                 Width="460"
                                 Text="{CompiledBinding Series.SeriesNotes, Mode=TwoWay}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 BorderThickness="2"
                                 PlaceholderText="Notes..."
                                 ScrollViewer.IsScrollChainingEnabled="false"
                                 FontWeight="Bold"
                                 FontSize="13"
                                 Classes="Menu"/>
                    </StackPanel>

                    <!-- Current Vols / Max Vols / Volumes Read / Rating -->
                    <Grid ColumnDefinitions="*,6,*,6,*,6,*" RowDefinitions="Auto,Auto" MinWidth="460">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="CURRENT VOLS" Classes="section-title" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                        <MaskedTextBox x:Name="CurVolumeMaskedTextBox"
                                       Grid.Row="1" Grid.Column="0"
                                       Height="34" HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       BorderThickness="2" FontWeight="Bold" FontSize="13"
                                       TextAlignment="Center" MaxLength="3"
                                       ToolTip.Tip="Current Volumes"
                                       Classes="Menu" Mask="###"/>

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="MAX VOLS" Classes="section-title" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                        <MaskedTextBox x:Name="MaxVolumeMaskedTextBox"
                                       Grid.Row="1" Grid.Column="2"
                                       Height="34" HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       BorderThickness="2" FontWeight="Bold" FontSize="13"
                                       TextAlignment="Center" MaxLength="3"
                                       ToolTip.Tip="Max Volumes"
                                       Classes="Menu" Mask="###"/>

                        <TextBlock Grid.Row="0" Grid.Column="4" Text="{CompiledBinding VolumesReadText}" Classes="section-title" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                        <MaskedTextBox x:Name="VolumesReadMaskedTextBox"
                                       Grid.Row="1" Grid.Column="4"
                                       Height="34" HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       BorderThickness="2" FontWeight="Bold" FontSize="13"
                                       TextAlignment="Center" MaxLength="3"
                                       Classes="Menu" Mask="000"/>

                        <TextBlock Grid.Row="0" Grid.Column="6" Text="RATING" Classes="section-title" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                        <MaskedTextBox x:Name="RatingMaskedTextBox"
                                       Grid.Row="1" Grid.Column="6"
                                       Height="34" HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       BorderThickness="2" FontWeight="Bold" FontSize="13"
                                       TextAlignment="Center" AcceptsReturn="False"
                                       HidePromptOnLeave="True"
                                       Classes="Menu" Mask="90.0\/\1\0.\0"/>
                    </Grid>

                    <!-- Cover Image URL -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="COVER IMAGE URL" Classes="section-title"
                                   ToolTip.Tip="{CompiledBinding CoverImageUrl}"/>
                        <Grid ColumnDefinitions="*,6,Auto,6,Auto">
                            <TextBox x:Name="CoverImageUrlTextBox"
                                     Grid.Column="0"
                                     FontSize="13" Height="34"
                                     FontWeight="Bold"
                                     Text="{CompiledBinding CoverImageUrl}"
                                     Classes="Menu" BorderThickness="2"
                                     PlaceholderText="Image URL..."/>
                            <Button x:Name="ChangeCoverLinkButton"
                                    Grid.Column="2"
                                    FontSize="14" Width="34" Height="34"
                                    Theme="{StaticResource MenuButton}"
                                    ToolTip.Tip="Change Cover From Link"
                                    Click="ChangeCoverFromLinkAsync">
                                <i:Icon x:Name="ChangeCoverButtonIcon" Value="fa7-solid fa7-circle-down" FontSize="14"/>
                            </Button>
                            <Button x:Name="ChangeCoverFileButton"
                                    Grid.Column="4"
                                    i:Attached.Icon="fa7-solid fa7-image"
                                    FontSize="14" Width="34" Height="34"
                                    Theme="{StaticResource MenuButton}"
                                    ToolTip.Tip="Change Cover From File"
                                    Click="ChangeSeriesCoverFromFileAsync"/>
                        </Grid>
                    </StackPanel>

                    <!-- Publisher / Value / Demographic -->
                    <Grid ColumnDefinitions="*,6,*,6,*" RowDefinitions="Auto,Auto" MinWidth="460">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="PUBLISHER" Classes="section-title" Margin="0,0,0,4" HorizontalAlignment="Center"
                                   ToolTip.Tip="{CompiledBinding Series.Publisher}"/>
                        <TextBox x:Name="PublisherTextBox"
                                 Grid.Row="1" Grid.Column="0"
                                 Height="34" HorizontalAlignment="Stretch"
                                 Classes="Menu" BorderThickness="2"
                                 FontWeight="Bold" FontSize="13"
                                 AcceptsReturn="False"
                                 Text="{CompiledBinding Series.Publisher, Mode=OneTime}"/>

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{CompiledBinding SeriesValueText}" Classes="section-title" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                        <MaskedTextBox x:Name="ValueMaskedTextBox"
                                       Grid.Row="1" Grid.Column="2"
                                       Height="34" HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       BorderThickness="2" FontWeight="Bold" FontSize="13"
                                       TextAlignment="Center" AcceptsReturn="False"
                                       Mask="{CompiledBinding SeriesValueMaskedText}"
                                       Classes="Menu"/>

                        <TextBlock Grid.Row="0" Grid.Column="4" Text="DEMOGRAPHIC" Classes="section-title" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                        <ComboBox x:Name="DemographicComboBox"
                                  Grid.Row="1" Grid.Column="4"
                                  ItemsSource="{x:Static enums:SeriesDemographicModel.SERIES_DEMOGRAPHIC_SET}"
                                  SelectionChanged="DemographicChanged"
                                  Height="34" FontWeight="Bold" FontSize="13"
                                  HorizontalAlignment="Stretch"
                                  SelectedIndex="{CompiledBinding DemographicIndex}"
                                  BorderThickness="2"
                                  Cursor="Hand"
                                  Theme="{StaticResource MenuComboBox}"
                                  ItemContainerTheme="{StaticResource MenuComboBoxItem}"
                                  AutoScrollToSelectedItem="True">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <!-- Action Buttons -->
                    <Border Classes="divider"/>
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <Button x:Name="ChangeSeriesVolumeCountButton"
                                Theme="{StaticResource MenuButton}"
                                Height="34" Padding="14,0" FontSize="13"
                                ToolTip.Tip="Refresh series data from AniList"
                                Click="RefreshSeriesAsync">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <i:Icon Value="fa7-solid fa7-arrows-rotate" FontSize="13"/>
                                <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Theme="{StaticResource MenuButton}"
                                Height="34" Padding="14,0" FontSize="13"
                                ToolTip.Tip="Save Stats"
                                Click="SaveStats">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <i:Icon Value="fa7-solid fa7-floppy-disk" FontSize="13"/>
                                <TextBlock Text="Save" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <ToggleButton x:Name="FavoriteButton"
                                      IsChecked="{CompiledBinding Series.IsFavorite, Mode=TwoWay}"
                                      Theme="{StaticResource MenuToggleButton}"
                                      Height="34" Width="34" FontSize="14"
                                      ToolTip.Tip="Favorite"
                                      i:Attached.Icon="fa7-solid fa7-heart"/>
                    </StackPanel>
                </StackPanel>

                <!-- RIGHT COLUMN: Genres -->
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="GENRES" Classes="section-title"
                               ToolTip.Tip="{CompiledBinding GenresToolTipText}"
                               ToolTip.IsEnabled="{CompiledBinding GenresToolTipText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <ListBox x:Name="GenreSelector"
                             Height="417"
                             ItemsSource="{x:Static enums:SeriesGenreModel.SERIES_GENRES}"
                             SelectedItems="{CompiledBinding SelectedGenres}"
                             SelectionMode="Multiple,Toggle"
                             SelectionChanged="GenreSelectionChanged"
                             ItemContainerTheme="{StaticResource QueryListBoxItem}"
                             Theme="{StaticResource QueryListBox}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
