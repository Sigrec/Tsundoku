<Window xmlns="https://github.com/avaloniaui"
        xmlns:vm="using:Tsundoku.ViewModels"
        xmlns:c="using:Tsundoku.CustomControls"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:help="clr-namespace:Tsundoku.Helpers"
		xmlns:cv="clr-namespace:Tsundoku.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="clr-namespace:Projektanker.Icons.Avalonia;assembly=Projektanker.Icons.Avalonia"
        xmlns:controls="clr-namespace:Tsundoku.Controls"
        x:Class="Tsundoku.Views.CollectionThemeWindow"
        Icon="\Assets\Icons\TsundokuLogo.ico"
        Title="Theme"
        FontFamily="Segoe UI"
        WindowState="2"
        Classes="Menu"
        WindowStartupLocation="2"
        KeyboardNavigation.TabNavigation="None"
        x:DataType="vm:ThemeSettingsViewModel"
        x:Name="Root"
        CanResize="true">
    <Window.Resources>
        <ResourceDictionary>
            <cv:BrushToColorConverter x:Key="BrushToColorConverter"/>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Styles/ThemeSettingsControlThemes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

	<Border Classes="Menu" BorderThickness="2" CornerRadius="0,0,8,8" ClipToBounds="True">
		<ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Theme="{StaticResource ReverseCollectionScroll}">
			<StackPanel Spacing="10" Margin="20,10,20,20" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border BorderBrush="{DynamicResource TsundokuDividerColor}" BorderThickness="0,0,0,3">
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="Menu / Nav Bar" FontSize="30" FontWeight="Bold" Classes="Menu" HorizontalAlignment="Center" TextDecorations="Underline"/>
                        <WrapPanel>
                            <controls:ColorPickerItem Title="Menu BG" ColorBrush="{Binding CurrentTheme.MenuBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Username" ColorBrush="{Binding CurrentTheme.UsernameColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="User Icon Border" ColorBrush="{Binding CurrentTheme.UserIconBorderColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu Text" ColorBrush="{Binding CurrentTheme.MenuTextColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Search Bar BG" ColorBrush="{Binding CurrentTheme.SearchBarBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Search Bar Border" ColorBrush="{Binding CurrentTheme.SearchBarBorderColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Search Bar Text" ColorBrush="{Binding CurrentTheme.SearchBarTextColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Divider" ColorBrush="{Binding CurrentTheme.DividerColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu Button BG" ColorBrush="{Binding CurrentTheme.MenuButtonBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu Button BG (Hover)" ColorBrush="{Binding CurrentTheme.MenuButtonBGHoverColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu Button Border" ColorBrush="{Binding CurrentTheme.MenuButtonBorderColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu Button Border (Hover)" ColorBrush="{Binding CurrentTheme.MenuButtonBorderHoverColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu Button Icon/Text" ColorBrush="{Binding CurrentTheme.MenuButtonTextAndIconColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu Button Icon/Text (Hover)" ColorBrush="{Binding CurrentTheme.MenuButtonTextAndIconHoverColor, Mode=TwoWay}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
                <Border BorderBrush="{DynamicResource TsundokuDividerColor}" BorderThickness="0,0,0,3">
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="Collection" FontSize="30" FontWeight="Bold" Classes="Menu" HorizontalAlignment="Center" TextDecorations="Underline"/>
                        <WrapPanel>
                            <WrapPanel.Styles>
                                <Style Selector="Button">
                                    <Style Selector="^:pressed">
                                        <Setter Property="RenderTransform" Value="scale(1)" />
                                    </Style>
                                </Style>
                            </WrapPanel.Styles>
                            <controls:ColorPickerItem Title="Collection BG" ColorBrush="{Binding CurrentTheme.CollectionBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Status And BookType BG" ColorBrush="{Binding CurrentTheme.StatusAndBookTypeBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Status And BookType BG (Hover)" ColorBrush="{Binding CurrentTheme.StatusAndBookTypeBGHoverColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Status And BookType Text" ColorBrush="{Binding CurrentTheme.StatusAndBookTypeTextColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Status And BookType Text (Hover)" ColorBrush="{Binding CurrentTheme.StatusAndBookTypeTextHoverColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Card BG" ColorBrush="{Binding CurrentTheme.SeriesCardBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Title" ColorBrush="{Binding CurrentTheme.SeriesCardTitleColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Publisher" ColorBrush="{Binding CurrentTheme.SeriesCardPublisherColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Staff" ColorBrush="{Binding CurrentTheme.SeriesCardStaffColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Description" ColorBrush="{Binding CurrentTheme.SeriesCardDescColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Progress BG" ColorBrush="{Binding CurrentTheme.SeriesProgressBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Progress Bar" ColorBrush="{Binding CurrentTheme.SeriesProgressBarColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Progress Bar BG" ColorBrush="{Binding CurrentTheme.SeriesProgressBarBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Progress Bar Border" ColorBrush="{Binding CurrentTheme.SeriesProgressBarBorderColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Progress Text" ColorBrush="{Binding CurrentTheme.SeriesProgressTextColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Progress Buttons (Hover)" ColorBrush="{Binding CurrentTheme.SeriesProgressButtonsHoverColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Button Icon" ColorBrush="{Binding CurrentTheme.SeriesButtonIconColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Button Icon (Hover)" ColorBrush="{Binding CurrentTheme.SeriesButtonIconHoverColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Edit Pane BG" ColorBrush="{Binding CurrentTheme.SeriesEditPaneBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Notes BG" ColorBrush="{Binding CurrentTheme.SeriesNotesBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Notes Border" ColorBrush="{Binding CurrentTheme.SeriesNotesBorderColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Notes Text" ColorBrush="{Binding CurrentTheme.SeriesNotesTextColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Edit Pane Buttons BG" ColorBrush="{Binding CurrentTheme.SeriesEditPaneButtonsBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Edit Button BG (Hover)" ColorBrush="{Binding CurrentTheme.SeriesEditPaneButtonsBGHoverColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Edit Pane Buttons Border" ColorBrush="{Binding CurrentTheme.SeriesEditPaneButtonsBorderColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Edit Pane Buttons Border (Hover)" ColorBrush="{Binding CurrentTheme.SeriesEditPaneButtonsBorderHoverColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Edit Pane Button Icon" ColorBrush="{Binding CurrentTheme.SeriesEditPaneButtonsIconColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Edit Pane Button Icon (Hover)" ColorBrush="{Binding CurrentTheme.SeriesEditPaneButtonsIconHoverColor, Mode=TwoWay}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
                <Border BorderBrush="{DynamicResource TsundokuDividerColor}" BorderThickness="0,0,0,3">
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="Theme Change" FontSize="30" HorizontalAlignment="Center" FontWeight="Bold" Classes="Menu"  TextDecorations="Underline"/>
                        <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,10,0,0">
                            <Button x:Name="ExportThemeButton"
                                    Content="Export"
                                    Height="35"
                                    Theme="{StaticResource MenuButton}"
                                    Click="ExportThemeAsync"/>
                            <Button x:Name="ImportThemeButton"
                                    Content="Import"
                                    Height="35"
                                    Theme="{StaticResource MenuButton}"
                                    Click="ImportThemeAsync"/>
                            <TextBox x:Name="NewThemeName"
                                    Width="250"
                                    Height="35"
                                    FontSize="15"
                                    Classes="Menu"
                                    FontWeight="Bold"
                                    BorderThickness="2"/>
                            <Button x:Name="SaveThemeButton"
                                    Content="Save"
                                    Height="35"
                                    IsEnabled="{CompiledBinding IsSaveThemeButtonEnabled}"
                                    Theme="{StaticResource MenuButton}"
                                    Click="SaveNewTheme"/>
                            <ComboBox x:Name="ThemeSelector"
                                    SelectionChanged="ChangeMainTheme"
                                    Height="35"
                                    ItemsSource="{CompiledBinding SavedThemes, Mode=OneWay}"
                                    SelectedIndex="{CompiledBinding SelectedThemeIndex, Mode=OneWay}"
                                    BorderThickness="2"
                                    ItemContainerTheme="{StaticResource MenuComboBoxItem}"
                                    Theme="{StaticResource MenuComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ThemeName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button FontSize="20"
                                    Theme="{StaticResource MenuButton}"
                                    Height="35"
                                    i:Attached.Icon="fa-xmark"
                                    Click="RemoveSavedTheme"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
				<StackPanel HorizontalAlignment="Center">
					<TextBlock Text="Generate Theme" FontSize="30" HorizontalAlignment="Center" FontWeight="Bold" Classes="Menu" TextDecorations="Underline"/>
					<Grid ColumnDefinitions="45,3,110,110,110,110,110,110,3,45,5,45" RowDefinitions="*,*" Margin="0,10,0,0">
						<Button FontSize="20"
								FontWeight="Bold"
								Grid.Row="1"
								Grid.Column="0"
								Theme="{StaticResource MenuButton}"
								i:Attached.Icon="fa-xmark"
								Click="ClearThemeValues"/>
						<TextBlock Classes="Menu" Text="Main Color 1" FontSize="14" Margin="3,0,0,2" FontWeight="Bold" Grid.Row="0" Grid.Column="2"/>
						<MaskedTextBox x:Name="MainColor1"
								 	   Width="105"
								 	   FontSize="15"
								 	   Grid.Row="1"
								 	   Grid.Column="2"
								 	   Classes="Menu"
								 	   FontWeight="Bold"
								 	   Mask="\#AAAAAA"
								 	   BorderThickness="2"/>
						<TextBlock Classes="Menu" Text="Main Color 2" FontSize="14" Margin="3,0,0,2" FontWeight="Bold" Grid.Row="0" Grid.Column="3"/>
						<MaskedTextBox x:Name="MainColor2"
								 	   Width="105"
								 	   FontSize="15"
								 	   Grid.Row="1"
								 	   Grid.Column="3"
								 	   Classes="Menu"
								 	   FontWeight="Bold"
								 	   Mask="\#AAAAAA"
								 	   BorderThickness="2"/>
						<TextBlock Classes="Menu" Text="Text Color 1" FontSize="14" Margin="3,0,0,2" FontWeight="Bold" Grid.Row="0" Grid.Column="4"/>
						<MaskedTextBox x:Name="TextColor1"
								 	   Width="105"
								 	   FontSize="15"
								 	   Grid.Row="1"
								 	   Grid.Column="4"
								 	   Classes="Menu"
								 	   FontWeight="Bold"
								 	   Mask="\#AAAAAA"
								 	   BorderThickness="2"/>
						<TextBlock Classes="Menu" Text="Text Color 2" FontSize="14" Margin="3,0,0,2" FontWeight="Bold" Grid.Row="0" Grid.Column="5"/>
						<MaskedTextBox x:Name="TextColor2"
								 	   Width="105"
								 	   FontSize="15"
								 	   Grid.Row="1"
								 	   Grid.Column="5"
								 	   Classes="Menu"
								 	   FontWeight="Bold"
								 	   Mask="\#AAAAAA"
								 	   BorderThickness="2"/>
						<TextBlock Classes="Menu" Text="Accent Color 1" FontSize="14" Margin="3,0,0,2" FontWeight="Bold" Grid.Row="0" Grid.Column="6"/>
						<MaskedTextBox x:Name="AccentColor1"
									   Width="105"
									   FontSize="15"
									   Grid.Row="1"
									   Grid.Column="6"
									   Classes="Menu"
									   FontWeight="Bold"
									   Mask="\#AAAAAA"
									   BorderThickness="2"/>
						<TextBlock Classes="Menu" Text="Accent Color 2" FontSize="14" Margin="3,0,0,2" FontWeight="Bold" Grid.Row="0" Grid.Column="7"/>
						<MaskedTextBox x:Name="AccentColor2"
								 	   Width="105"
								 	   FontSize="15"
								 	   Grid.Row="1"
								 	   Grid.Column="7"
								 	   Classes="Menu"
								 	   FontWeight="Bold"
								 	   Mask="\#AAAAAA"
								 	   BorderThickness="2"/>
						<Button FontSize="20"
								Theme="{StaticResource MenuButton}"
								Grid.Row="1"
								Grid.Column="9"
								ToolTip.Tip="Theme 1"
								i:Attached.Icon="fa-1"
								IsEnabled="{CompiledBinding IsGenerateThemeButtonEnabled}"
								Click="GenerateThemeType1"/>
						<Button FontSize="20"
                                Theme="{StaticResource MenuButton}"
								Grid.Row="1"
								Grid.Column="11"
								ToolTip.Tip="Theme 2"
								i:Attached.Icon="fa-2"
								IsEnabled="{CompiledBinding IsGenerateThemeButtonEnabled}"
								Click="GenerateThemeType2"/>
					</Grid>
				</StackPanel>
			</StackPanel>
		</ScrollViewer>
	</Border>
</Window>
