<Window xmlns="https://github.com/avaloniaui"
        xmlns:vm="using:Tsundoku.ViewModels"
        xmlns:c="using:Tsundoku.CustomControls"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:help="clr-namespace:Tsundoku.Helpers"
		xmlns:cv="clr-namespace:Tsundoku.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="clr-namespace:Optris.Icons.Avalonia;assembly=Optris.Icons.Avalonia"
        xmlns:controls="clr-namespace:Tsundoku.Controls"
        xmlns:m="clr-namespace:Tsundoku.Models"
        x:Class="Tsundoku.Views.CollectionThemeWindow"
        Icon="\Assets\Icons\TsundokuLogo.ico"
        Title="Theme"
        SizeToContent="WidthAndHeight"
        MinWidth="420"
        MaxWidth="790"
        MinHeight="700"
        MaxHeight="950"
        Classes="Menu"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        KeyboardNavigation.TabNavigation="None"
        x:DataType="vm:ThemeSettingsViewModel"
        x:Name="Root">
    <Window.Resources>
        <ResourceDictionary>
            <cv:BrushToColorConverter x:Key="BrushToColorConverter"/>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Styles/ThemeSettingsControlThemes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

	<Border Classes="Menu" BorderThickness="2" CornerRadius="0,0,8,8" ClipToBounds="True">
		<Grid RowDefinitions="Auto,*">
			<!-- Header -->
			<controls:WindowHeader Grid.Row="0" Icon="fa7-solid fa7-swatchbook" Title="Theme Settings"/>

		<ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden" Theme="{StaticResource ReverseCollectionScroll}">
			<StackPanel Spacing="0">
                <!-- Menu / Nav Bar -->
                <StackPanel Margin="20,14,20,14">
                    <TextBlock Text="MENU / NAV BAR" Classes="section-title" Margin="0,0,0,10"/>
                        <WrapPanel>
                            <controls:ColorPickerItem Title="Divider" ColorBrush="{CompiledBinding CurrentTheme.DividerColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu BG" ColorBrush="{CompiledBinding CurrentTheme.MenuBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu Button BG" ColorBrush="{CompiledBinding CurrentTheme.MenuButtonBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu Button BG Hover" ColorBrush="{CompiledBinding CurrentTheme.MenuButtonBGHoverColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu Button Border" ColorBrush="{CompiledBinding CurrentTheme.MenuButtonBorderColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu Button Border Hover" ColorBrush="{CompiledBinding CurrentTheme.MenuButtonBorderHoverColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu Button Icon" ColorBrush="{CompiledBinding CurrentTheme.MenuButtonTextAndIconColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu Button Icon Hover" ColorBrush="{CompiledBinding CurrentTheme.MenuButtonTextAndIconHoverColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu Text" ColorBrush="{CompiledBinding CurrentTheme.MenuTextColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Search Bar BG" ColorBrush="{CompiledBinding CurrentTheme.SearchBarBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Search Bar Border" ColorBrush="{CompiledBinding CurrentTheme.SearchBarBorderColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Search Bar Text" ColorBrush="{CompiledBinding CurrentTheme.SearchBarTextColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Username" ColorBrush="{CompiledBinding CurrentTheme.UsernameColor, Mode=TwoWay}"/>
                        </WrapPanel>
                </StackPanel>

                <!-- Collection -->
                <Border Classes="divider"/>
                <StackPanel Margin="20,14,20,14">
                    <TextBlock Text="COLLECTION" Classes="section-title" Margin="0,0,0,10"/>
                        <WrapPanel>
                            <controls:ColorPickerItem Title="Badge BG" ColorBrush="{CompiledBinding CurrentTheme.StatusAndBookTypeBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Badge Border" ColorBrush="{CompiledBinding CurrentTheme.StatusAndBookTypeBorderColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Badge Text" ColorBrush="{CompiledBinding CurrentTheme.StatusAndBookTypeTextColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Button Icon" ColorBrush="{CompiledBinding CurrentTheme.SeriesButtonIconColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Button Icon Hover" ColorBrush="{CompiledBinding CurrentTheme.SeriesButtonIconHoverColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Card Border" ColorBrush="{CompiledBinding CurrentTheme.SeriesCardBorderColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Card Button BG" ColorBrush="{CompiledBinding CurrentTheme.SeriesCardButtonBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Card Button BG Hover" ColorBrush="{CompiledBinding CurrentTheme.SeriesCardButtonBGHoverColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Card Button Border" ColorBrush="{CompiledBinding CurrentTheme.SeriesCardButtonBorderColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Card Button Border Hover" ColorBrush="{CompiledBinding CurrentTheme.SeriesCardButtonBorderHoverColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Card Divider" ColorBrush="{CompiledBinding CurrentTheme.SeriesCardDividerColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Collection BG" ColorBrush="{CompiledBinding CurrentTheme.CollectionBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Cover BG" ColorBrush="{CompiledBinding CurrentTheme.SeriesCoverBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Progress Bar" ColorBrush="{CompiledBinding CurrentTheme.SeriesProgressBarColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Progress Bar BG" ColorBrush="{CompiledBinding CurrentTheme.SeriesProgressBarBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Progress Bar Border" ColorBrush="{CompiledBinding CurrentTheme.SeriesProgressBarBorderColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Progress Text" ColorBrush="{CompiledBinding CurrentTheme.SeriesProgressTextColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Card BG" ColorBrush="{CompiledBinding CurrentTheme.SeriesCardBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Description" ColorBrush="{CompiledBinding CurrentTheme.SeriesCardDescColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Publisher" ColorBrush="{CompiledBinding CurrentTheme.SeriesCardPublisherColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Staff" ColorBrush="{CompiledBinding CurrentTheme.SeriesCardStaffColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Title" ColorBrush="{CompiledBinding CurrentTheme.SeriesCardTitleColor, Mode=TwoWay}"/>
                        </WrapPanel>
                </StackPanel>

                <!-- Theme Management -->
                <Border Classes="divider"/>
                <StackPanel Margin="20,14,20,14" Spacing="8">
                    <TextBlock Text="THEME MANAGEMENT" Classes="section-title"/>
                    <Grid ColumnDefinitions="Auto,Auto,6,*,Auto">
                        <Button x:Name="ExportThemeButton" Content="Export" Height="34" Padding="14,0" FontSize="13" Margin="0,0,6,0"
                                Theme="{StaticResource MenuButton}" Click="ExportThemeAsync" i:Attached.Icon="fa7-solid fa7-file-export"/>
                        <Button x:Name="ImportThemeButton" Grid.Column="1" Content="Import" Height="34" Padding="14,0" FontSize="13"
                                Theme="{StaticResource MenuButton}" Click="ImportThemeAsync" i:Attached.Icon="fa7-solid fa7-file-import"/>
                        <TextBox x:Name="NewThemeName" Grid.Column="3" Height="34" FontSize="13" Classes="Menu" FontWeight="Bold" BorderThickness="2" PlaceholderText="New theme name..."/>
                        <Button x:Name="SaveThemeButton" Grid.Column="4" Content="Save" Height="34" Padding="14,0" FontSize="13" Margin="6,0,0,0"
                                IsEnabled="{CompiledBinding IsSaveThemeButtonEnabled}" Theme="{StaticResource MenuButton}" Click="SaveNewTheme"
                                i:Attached.Icon="fa7-solid fa7-floppy-disk"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <ComboBox x:Name="ThemeSelector" SelectionChanged="ChangeMainTheme" Height="34"
                                  ItemsSource="{CompiledBinding SavedThemes, Mode=OneWay}" SelectedIndex="{CompiledBinding SelectedThemeIndex, Mode=OneWay}"
                                  ItemContainerTheme="{StaticResource MenuComboBoxItem}" Theme="{StaticResource MenuComboBox}" HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="m:TsundokuTheme"><TextBlock Text="{CompiledBinding ThemeName}"/></DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Grid.Column="1" FontSize="14" Width="34" Height="34" Margin="6,0,0,0"
                                Theme="{StaticResource MenuButton}" i:Attached.Icon="fa7-solid fa7-trash" Click="RemoveSavedTheme"/>
                    </Grid>
                </StackPanel>

                <!-- Generate Theme -->
                <Border Classes="divider"/>
                <StackPanel Margin="20,14,20,14" Spacing="8">
                    <TextBlock Text="GENERATE THEME" Classes="section-title"/>
                    <WrapPanel>
                        <StackPanel Spacing="3" Margin="3">
                            <TextBlock Text="MAIN COLOR 1" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TsundokuDividerColor}"/>
                            <MaskedTextBox x:Name="MainColor1" FontSize="13" Classes="Menu" FontWeight="Bold" Mask="\#AAAAAA" BorderThickness="2" Height="34" MinWidth="100"/>
                        </StackPanel>
                        <StackPanel Spacing="3" Margin="3">
                            <TextBlock Text="MAIN COLOR 2" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TsundokuDividerColor}"/>
                            <MaskedTextBox x:Name="MainColor2" FontSize="13" Classes="Menu" FontWeight="Bold" Mask="\#AAAAAA" BorderThickness="2" Height="34" MinWidth="100"/>
                        </StackPanel>
                        <StackPanel Spacing="3" Margin="3">
                            <TextBlock Text="TEXT COLOR 1" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TsundokuDividerColor}"/>
                            <MaskedTextBox x:Name="TextColor1" FontSize="13" Classes="Menu" FontWeight="Bold" Mask="\#AAAAAA" BorderThickness="2" Height="34" MinWidth="100"/>
                        </StackPanel>
                        <StackPanel Spacing="3" Margin="3">
                            <TextBlock Text="TEXT COLOR 2" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TsundokuDividerColor}"/>
                            <MaskedTextBox x:Name="TextColor2" FontSize="13" Classes="Menu" FontWeight="Bold" Mask="\#AAAAAA" BorderThickness="2" Height="34" MinWidth="100"/>
                        </StackPanel>
                        <StackPanel Spacing="3" Margin="3">
                            <TextBlock Text="ACCENT COLOR 1" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TsundokuDividerColor}"/>
                            <MaskedTextBox x:Name="AccentColor1" FontSize="13" Classes="Menu" FontWeight="Bold" Mask="\#AAAAAA" BorderThickness="2" Height="34" MinWidth="100"/>
                        </StackPanel>
                        <StackPanel Spacing="3" Margin="3">
                            <TextBlock Text="ACCENT COLOR 2" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TsundokuDividerColor}"/>
                            <MaskedTextBox x:Name="AccentColor2" FontSize="13" Classes="Menu" FontWeight="Bold" Mask="\#AAAAAA" BorderThickness="2" Height="34" MinWidth="100"/>
                        </StackPanel>
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Theme="{StaticResource MenuButton}" Height="34" Padding="14,0" FontSize="13"
                                i:Attached.Icon="fa7-solid fa7-eraser" Content="Clear" Click="ClearThemeValues"/>
                        <Button Theme="{StaticResource MenuButton}" Height="34" Padding="14,0" FontSize="13"
                                i:Attached.Icon="fa7-solid fa7-wand-magic-sparkles" Content="Generate 1"
                                ToolTip.Tip="Classy style: main color for hover icons, text color for progress bar"
                                IsEnabled="{CompiledBinding IsGenerateThemeButtonEnabled}" Click="GenerateThemeType1"/>
                        <Button Theme="{StaticResource MenuButton}" Height="34" Padding="14,0" FontSize="13"
                                i:Attached.Icon="fa7-solid fa7-wand-magic-sparkles" Content="Generate 2"
                                ToolTip.Tip="Electric Rose style: accent color for progress bar and hover icons"
                                IsEnabled="{CompiledBinding IsGenerateThemeButtonEnabled}" Click="GenerateThemeType2"/>
                        <Button x:Name="GenerateApiButton" Theme="{StaticResource MenuButton}" Height="34" Padding="14,0" FontSize="13"
                                i:Attached.Icon="fa7-solid fa7-palette" Content="Auto Generate"
                                ToolTip.Tip="Generate a full color palette from Main Color 1 using the Color API"
                                Click="GenerateFromColorApiAsync"/>
                    </StackPanel>
                </StackPanel>
			</StackPanel>
		</ScrollViewer>
		</Grid>
	</Border>
</Window>
