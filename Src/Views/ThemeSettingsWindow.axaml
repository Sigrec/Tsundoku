<Window xmlns="https://github.com/avaloniaui"
        xmlns:vm="using:Tsundoku.ViewModels"
        xmlns:c="using:Tsundoku.CustomControls"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:help="clr-namespace:Tsundoku.Helpers"
		xmlns:cv="clr-namespace:Tsundoku.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="clr-namespace:Projektanker.Icons.Avalonia;assembly=Projektanker.Icons.Avalonia"
        xmlns:controls="clr-namespace:Tsundoku.Controls"
        x:Class="Tsundoku.Views.CollectionThemeWindow"
        Icon="\Assets\Icons\TsundokuLogo.ico"
        Title="Theme"
        SizeToContent="WidthAndHeight"
        MinWidth="420"
        MaxWidth="790"
        MinHeight="700"
        MaxHeight="950"
        Classes="Menu"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        KeyboardNavigation.TabNavigation="None"
        x:DataType="vm:ThemeSettingsViewModel"
        x:Name="Root">
    <Window.Resources>
        <ResourceDictionary>
            <cv:BrushToColorConverter x:Key="BrushToColorConverter"/>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Styles/ThemeSettingsControlThemes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

	<Border Classes="Menu" BorderThickness="2" CornerRadius="0,0,8,8" ClipToBounds="True">
		<Grid RowDefinitions="Auto,*">
			<!-- Header -->
			<Border Grid.Row="0" BorderThickness="0,0,0,2" BorderBrush="{DynamicResource TsundokuDividerColor}" Padding="16,12">
				<StackPanel Orientation="Horizontal" Spacing="8">
					<i:Icon Value="fa-solid fa-swatchbook" FontSize="16" Foreground="{DynamicResource TsundokuDividerColor}"/>
					<TextBlock Text="Theme Settings" FontSize="18" FontWeight="ExtraBold" Foreground="{DynamicResource TsundokuUsernameColor}" VerticalAlignment="Center"/>
				</StackPanel>
			</Border>

		<ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden" Theme="{StaticResource ReverseCollectionScroll}">
			<StackPanel Spacing="0">
                <!-- Menu / Nav Bar -->
                <StackPanel Margin="20,14,20,14">
                    <TextBlock Text="MENU / NAV BAR" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TsundokuSeriesCardPublisherColor}" LetterSpacing="1" Opacity="0.8" Margin="0,0,0,10"/>
                        <WrapPanel>
                            <controls:ColorPickerItem Title="Divider" ColorBrush="{Binding CurrentTheme.DividerColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu BG" ColorBrush="{Binding CurrentTheme.MenuBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu Button BG" ColorBrush="{Binding CurrentTheme.MenuButtonBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu Button BG Hover" ColorBrush="{Binding CurrentTheme.MenuButtonBGHoverColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu Button Border" ColorBrush="{Binding CurrentTheme.MenuButtonBorderColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu Button Border Hover" ColorBrush="{Binding CurrentTheme.MenuButtonBorderHoverColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu Button Icon" ColorBrush="{Binding CurrentTheme.MenuButtonTextAndIconColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu Button Icon Hover" ColorBrush="{Binding CurrentTheme.MenuButtonTextAndIconHoverColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Menu Text" ColorBrush="{Binding CurrentTheme.MenuTextColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Search Bar BG" ColorBrush="{Binding CurrentTheme.SearchBarBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Search Bar Border" ColorBrush="{Binding CurrentTheme.SearchBarBorderColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Search Bar Text" ColorBrush="{Binding CurrentTheme.SearchBarTextColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Username" ColorBrush="{Binding CurrentTheme.UsernameColor, Mode=TwoWay}"/>
                        </WrapPanel>
                </StackPanel>

                <!-- Collection -->
                <Border BorderThickness="0,2,0,0" BorderBrush="{DynamicResource TsundokuDividerColor}" Opacity="0.3"/>
                <StackPanel Margin="20,14,20,14">
                    <TextBlock Text="COLLECTION" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TsundokuSeriesCardPublisherColor}" LetterSpacing="1" Opacity="0.8" Margin="0,0,0,10"/>
                        <WrapPanel>
                            <controls:ColorPickerItem Title="Badge BG" ColorBrush="{Binding CurrentTheme.StatusAndBookTypeBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Badge Border" ColorBrush="{Binding CurrentTheme.StatusAndBookTypeBorderColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Badge Text" ColorBrush="{Binding CurrentTheme.StatusAndBookTypeTextColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Button Icon" ColorBrush="{Binding CurrentTheme.SeriesButtonIconColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Button Icon Hover" ColorBrush="{Binding CurrentTheme.SeriesButtonIconHoverColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Card Border" ColorBrush="{Binding CurrentTheme.SeriesCardBorderColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Card Button BG" ColorBrush="{Binding CurrentTheme.SeriesCardButtonBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Card Button BG Hover" ColorBrush="{Binding CurrentTheme.SeriesCardButtonBGHoverColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Card Button Border" ColorBrush="{Binding CurrentTheme.SeriesCardButtonBorderColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Card Button Border Hover" ColorBrush="{Binding CurrentTheme.SeriesCardButtonBorderHoverColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Card Divider" ColorBrush="{Binding CurrentTheme.SeriesCardDividerColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Collection BG" ColorBrush="{Binding CurrentTheme.CollectionBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Cover BG" ColorBrush="{Binding CurrentTheme.SeriesCoverBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Progress Bar" ColorBrush="{Binding CurrentTheme.SeriesProgressBarColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Progress Bar BG" ColorBrush="{Binding CurrentTheme.SeriesProgressBarBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Progress Bar Border" ColorBrush="{Binding CurrentTheme.SeriesProgressBarBorderColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Progress Text" ColorBrush="{Binding CurrentTheme.SeriesProgressTextColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Card BG" ColorBrush="{Binding CurrentTheme.SeriesCardBGColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Description" ColorBrush="{Binding CurrentTheme.SeriesCardDescColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Publisher" ColorBrush="{Binding CurrentTheme.SeriesCardPublisherColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Staff" ColorBrush="{Binding CurrentTheme.SeriesCardStaffColor, Mode=TwoWay}"/>
                            <controls:ColorPickerItem Title="Series Title" ColorBrush="{Binding CurrentTheme.SeriesCardTitleColor, Mode=TwoWay}"/>
                        </WrapPanel>
                </StackPanel>

                <!-- Theme Management -->
                <Border BorderThickness="0,2,0,0" BorderBrush="{DynamicResource TsundokuDividerColor}" Opacity="0.3"/>
                <StackPanel Margin="20,14,20,14" Spacing="8">
                    <TextBlock Text="THEME MANAGEMENT" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TsundokuSeriesCardPublisherColor}" LetterSpacing="1" Opacity="0.8"/>
                    <Grid ColumnDefinitions="Auto,Auto,6,*,Auto">
                        <Button x:Name="ExportThemeButton" Content="Export" Height="34" Padding="14,0" FontSize="13" Margin="0,0,6,0"
                                Theme="{StaticResource MenuButton}" Click="ExportThemeAsync" i:Attached.Icon="fa-solid fa-file-export"/>
                        <Button x:Name="ImportThemeButton" Grid.Column="1" Content="Import" Height="34" Padding="14,0" FontSize="13"
                                Theme="{StaticResource MenuButton}" Click="ImportThemeAsync" i:Attached.Icon="fa-solid fa-file-import"/>
                        <TextBox x:Name="NewThemeName" Grid.Column="3" Height="34" FontSize="13" Classes="Menu" FontWeight="Bold" BorderThickness="2" Watermark="New theme name..."/>
                        <Button x:Name="SaveThemeButton" Grid.Column="4" Content="Save" Height="34" Padding="14,0" FontSize="13" Margin="6,0,0,0"
                                IsEnabled="{CompiledBinding IsSaveThemeButtonEnabled}" Theme="{StaticResource MenuButton}" Click="SaveNewTheme"
                                i:Attached.Icon="fa-solid fa-floppy-disk"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <ComboBox x:Name="ThemeSelector" SelectionChanged="ChangeMainTheme" Height="34"
                                  ItemsSource="{CompiledBinding SavedThemes, Mode=OneWay}" SelectedIndex="{CompiledBinding SelectedThemeIndex, Mode=OneWay}"
                                  ItemContainerTheme="{StaticResource MenuComboBoxItem}" Theme="{StaticResource MenuComboBox}" HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate><TextBlock Text="{Binding ThemeName}"/></DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Grid.Column="1" FontSize="14" Width="34" Height="34" Margin="6,0,0,0"
                                Theme="{StaticResource MenuButton}" i:Attached.Icon="fa-solid fa-trash" Click="RemoveSavedTheme"/>
                    </Grid>
                </StackPanel>

                <!-- Generate Theme -->
                <Border BorderThickness="0,2,0,0" BorderBrush="{DynamicResource TsundokuDividerColor}" Opacity="0.3"/>
                <StackPanel Margin="20,14,20,14" Spacing="8">
                    <TextBlock Text="GENERATE THEME" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TsundokuSeriesCardPublisherColor}" LetterSpacing="1" Opacity="0.8"/>
                    <WrapPanel>
                        <StackPanel Spacing="3" Margin="3">
                            <TextBlock Text="MAIN COLOR 1" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TsundokuDividerColor}"/>
                            <MaskedTextBox x:Name="MainColor1" FontSize="13" Classes="Menu" FontWeight="Bold" Mask="\#AAAAAA" BorderThickness="2" Height="34"/>
                        </StackPanel>
                        <StackPanel Spacing="3" Margin="3">
                            <TextBlock Text="MAIN COLOR 2" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TsundokuDividerColor}"/>
                            <MaskedTextBox x:Name="MainColor2" FontSize="13" Classes="Menu" FontWeight="Bold" Mask="\#AAAAAA" BorderThickness="2" Height="34"/>
                        </StackPanel>
                        <StackPanel Spacing="3" Margin="3">
                            <TextBlock Text="TEXT COLOR 1" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TsundokuDividerColor}"/>
                            <MaskedTextBox x:Name="TextColor1" FontSize="13" Classes="Menu" FontWeight="Bold" Mask="\#AAAAAA" BorderThickness="2" Height="34"/>
                        </StackPanel>
                        <StackPanel Spacing="3" Margin="3">
                            <TextBlock Text="TEXT COLOR 2" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TsundokuDividerColor}"/>
                            <MaskedTextBox x:Name="TextColor2" FontSize="13" Classes="Menu" FontWeight="Bold" Mask="\#AAAAAA" BorderThickness="2" Height="34"/>
                        </StackPanel>
                        <StackPanel Spacing="3" Margin="3">
                            <TextBlock Text="ACCENT COLOR 1" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TsundokuDividerColor}"/>
                            <MaskedTextBox x:Name="AccentColor1" FontSize="13" Classes="Menu" FontWeight="Bold" Mask="\#AAAAAA" BorderThickness="2" Height="34"/>
                        </StackPanel>
                        <StackPanel Spacing="3" Margin="3">
                            <TextBlock Text="ACCENT COLOR 2" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TsundokuDividerColor}"/>
                            <MaskedTextBox x:Name="AccentColor2" FontSize="13" Classes="Menu" FontWeight="Bold" Mask="\#AAAAAA" BorderThickness="2" Height="34"/>
                        </StackPanel>
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Theme="{StaticResource MenuButton}" Height="34" Padding="14,0" FontSize="13"
                                i:Attached.Icon="fa-solid fa-eraser" Content="Clear" Click="ClearThemeValues"/>
                        <Button Theme="{StaticResource MenuButton}" Height="34" Padding="14,0" FontSize="13"
                                i:Attached.Icon="fa-solid fa-wand-magic-sparkles" Content="Generate 1"
                                IsEnabled="{CompiledBinding IsGenerateThemeButtonEnabled}" Click="GenerateThemeType1"/>
                        <Button Theme="{StaticResource MenuButton}" Height="34" Padding="14,0" FontSize="13"
                                i:Attached.Icon="fa-solid fa-wand-magic-sparkles" Content="Generate 2"
                                IsEnabled="{CompiledBinding IsGenerateThemeButtonEnabled}" Click="GenerateThemeType2"/>
                    </StackPanel>
                </StackPanel>
			</StackPanel>
		</ScrollViewer>
		</Grid>
	</Border>
</Window>
