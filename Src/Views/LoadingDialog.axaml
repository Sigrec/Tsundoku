<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Tsundoku.ViewModels"
        CanResize="False"
        Width="400"
        SizeToContent="Height"
        ShowInTaskbar="False"
        Classes="Menu"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        x:DataType="vm:LoadingDialogViewModel"
        Topmost="True"
        x:Class="Tsundoku.Views.LoadingDialog">
    <Border Classes="Menu" BorderThickness="2" CornerRadius="14" ClipToBounds="True">
        <StackPanel Margin="20,16" Spacing="10">
            <TextBlock
                x:Name="StatusTextBlock"
                Classes="Menu"
                FontSize="18"
                HorizontalAlignment="Center"
                TextAlignment="Center"
                TextWrapping="Wrap"
                MaxWidth="360"
                FontWeight="Bold"/>
            <ProgressBar
                x:Name="LoadingProgressBar"
                Value="{CompiledBinding ProgressValue}"
                Maximum="{CompiledBinding ProgressMaximum}"
                IsIndeterminate="{CompiledBinding IsLoadingIndeterminate}"
                Background="{DynamicResource TsundokuSeriesProgressBarBGColor}"
                Foreground="{DynamicResource TsundokuSeriesProgressBarColor}"
                BorderBrush="{DynamicResource TsundokuSeriesProgressBarBorderColor}"
                BorderThickness="2"
                CornerRadius="6"
                Padding="3"
                Height="28" />
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    FontSize="13"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"
                    Padding="20,6"
                    CornerRadius="9"
                    BorderThickness="2"
                    Cursor="Hand"
                    IsVisible="False"
                    Theme="{StaticResource MenuButton}"
                    Click="OnCancelClicked"/>
        </StackPanel>
    </Border>
</Window>
