<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Tsundoku.ViewModels"
        x:Class="Tsundoku.Views.SeriesPickerWindow"
        Icon="\Assets\Icons\TsundokuLogo.ico"
        FontFamily="Segoe UI"
        Classes="Menu"
        WindowStartupLocation="CenterOwner"
        Width="450"
        Height="550"
        CanResize="False"
        Topmost="True"
        Title="Select Series to Refresh"
        x:DataType="vm:ViewModelBase">

    <Border Classes="Menu" BorderThickness="2" CornerRadius="0,0,8,8" ClipToBounds="True">
        <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">
            <!-- Search bar -->
            <TextBox x:Name="SearchBox"
                     Grid.Row="0"
                     Watermark="Search..."
                     FontSize="15"
                     FontWeight="Bold"
                     Height="35"
                     Classes="Menu"
                     BorderThickness="2"
                     Margin="0,0,0,8"/>

            <!-- Select All / Deselect All -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <Button Content="Select All"
                        FontSize="13"
                        FontWeight="Bold"
                        Padding="12,4"
                        Cursor="Hand"
                        Theme="{StaticResource MenuButton}"
                        Click="OnSelectAll"/>
                <Button Content="Deselect All"
                        FontSize="13"
                        FontWeight="Bold"
                        Padding="12,4"
                        Cursor="Hand"
                        Theme="{StaticResource MenuButton}"
                        Click="OnDeselectAll"/>
                <TextBlock x:Name="CountText"
                           FontSize="13"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Classes="Menu"/>
            </StackPanel>

            <!-- Series list -->
            <ListBox x:Name="SeriesList"
                     Grid.Row="2"
                     SelectionMode="Multiple,Toggle"
                     ItemContainerTheme="{StaticResource QueryListBoxItem}"
                     Theme="{StaticResource QueryListBox}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="14"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12" Margin="0,12,0,0">
                <Button Content="Refresh Selected"
                        FontSize="15"
                        FontWeight="Bold"
                        Padding="24,8"
                        CornerRadius="9"
                        BorderThickness="2"
                        Cursor="Hand"
                        Theme="{StaticResource MenuButton}"
                        Click="OnConfirm"/>
                <Button Content="Cancel"
                        FontSize="15"
                        FontWeight="Bold"
                        Padding="24,8"
                        CornerRadius="9"
                        BorderThickness="2"
                        Cursor="Hand"
                        Theme="{StaticResource MenuButton}"
                        Click="OnCancel"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
