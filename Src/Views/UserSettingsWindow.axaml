<Window xmlns="https://github.com/avaloniaui"
        xmlns:vm="using:Tsundoku.ViewModels"
        xmlns:models="clr-namespace:Tsundoku.Models"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="clr-namespace:Optris.Icons.Avalonia;assembly=Optris.Icons.Avalonia"
        xmlns:controls="clr-namespace:Tsundoku.Controls"
        x:Class="Tsundoku.Views.UserSettingsWindow"
        x:DataType="vm:UserSettingsViewModel"
        Icon="\Assets\Icons\TsundokuLogo.ico"
        Title="Settings"
        MaxWidth="491"
        MinWidth="491"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        KeyboardNavigation.TabNavigation="None">
    
    <Window.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Styles/UserSettingsControlThemes.xaml"/>
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</Window.Resources>

    <Window.Styles>
        <!-- Style ToggleButtons as toggle switches -->
        <Style Selector="ToggleButton.toggle-switch">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="11"/>
            <Setter Property="Background" Value="{DynamicResource TsundokuMenuButtonBGColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource TsundokuMenuButtonBorderColor}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Foreground" Value="{DynamicResource TsundokuDividerColor}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <Canvas Width="36" Height="18">
                            <Ellipse Width="12" Height="12"
                                     Fill="{TemplateBinding Foreground}"
                                     Canvas.Left="3" Canvas.Top="3"
                                     Name="Knob">
                                <Ellipse.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Canvas.Left" Duration="0:0:0.15"/>
                                    </Transitions>
                                </Ellipse.Transitions>
                            </Ellipse>
                        </Canvas>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.toggle-switch:pointerover">
            <Setter Property="Background" Value="{DynamicResource TsundokuMenuButtonBGHoverColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource TsundokuMenuButtonBorderHoverColor}"/>
        </Style>
        <Style Selector="ToggleButton.toggle-switch:checked">
            <Setter Property="Background" Value="{DynamicResource TsundokuSeriesProgressBarColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource TsundokuSeriesProgressBarColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource TsundokuMenuBGColor}"/>
        </Style>
        <Style Selector="ToggleButton.toggle-switch:checked /template/ Ellipse#Knob">
            <Setter Property="Canvas.Left" Value="21"/>
        </Style>
        <Style Selector="ToggleButton.toggle-switch:checked:pointerover">
            <Setter Property="Background" Value="{DynamicResource TsundokuSeriesProgressBarColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource TsundokuSeriesProgressBarColor}"/>
        </Style>
    </Window.Styles>

    <Border Classes="Menu" BorderThickness="2" CornerRadius="0,0,8,8" ClipToBounds="True">
        <Grid RowDefinitions="Auto,*">
            <!-- Header -->
            <controls:WindowHeader Grid.Row="0" Icon="fa7-solid fa7-gear" Title="Settings"/>

            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden" Theme="{StaticResource ReverseCollectionScroll}">
            <StackPanel>
                <!-- Profile -->
                <StackPanel Margin="20,16,20,14" Spacing="10">
                    <TextBlock Text="PROFILE" Classes="section-title"/>
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,0">
                        <TextBlock Text="Username" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TsundokuMenuTextColor}" Width="80"/>
                        <TextBox x:Name="UsernameChangeTextBox"
                                 Grid.Column="1"
                                 FontWeight="Bold"
                                 Classes="Menu"
                                 FontSize="13"
                                 MaxLength="20"
                                 PlaceholderText="Enter New Username..."
                                 Height="34"
                                 BorderThickness="2"
                                 CornerRadius="9"/>
                        <Button x:Name="ChangeUsernameButton"
                                Grid.Column="2"
                                Width="34" Height="34"
                                Margin="6,0,0,0"
                                Theme="{StaticResource MenuButton}"
                                i:Attached.Icon="fa7-check"
                                FontSize="14"
                                Click="ChangeUsername"
                                IsEnabled="{CompiledBinding IsChangeUsernameButtonEnabled}"/>
                    </Grid>
                </StackPanel>

                <!-- Memberships -->
                <Border Classes="divider"/>
                <StackPanel Margin="20,14,20,14" Spacing="6">
                    <TextBlock Text="MEMBERSHIPS" Classes="section-title" Margin="0,0,0,4"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Books-A-Million" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TsundokuMenuTextColor}"/>
                        <ToggleButton x:Name="BooksAMillionButton" Grid.Column="1" IsChecked="{CompiledBinding BooksAMillionMember}" Classes="toggle-switch" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Kinokuniya USA" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TsundokuMenuTextColor}"/>
                        <ToggleButton x:Name="KinokuniyaUSAButton" Grid.Column="1" IsChecked="{CompiledBinding KinokuniyaUSAMember}" Classes="toggle-switch" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <!-- Preferences -->
                <Border Classes="divider"/>
                <StackPanel Margin="20,14,20,14" Spacing="6">
                    <TextBlock Text="PREFERENCES" Classes="section-title" Margin="0,0,0,4"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Refresh Covers on Series Refresh" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TsundokuMenuTextColor}"/>
                        <ToggleButton x:Name="RefreshCoversButton" Grid.Column="1" IsChecked="{CompiledBinding RefreshCovers}" Classes="toggle-switch" VerticalAlignment="Center" ToolTip.Tip="Re-download cover images when refreshing an individual series"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Glass Effect" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TsundokuMenuTextColor}"/>
                        <ToggleButton x:Name="GlassmorphismButton" Grid.Column="1" IsChecked="{CompiledBinding GlassmorphismEnabled}" Classes="toggle-switch" VerticalAlignment="Center" ToolTip.Tip="Enable transparent blur effect on windows"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Currency" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TsundokuMenuTextColor}"/>
                        <ComboBox x:Name="CurrencyComboBox"
                                  Grid.Column="1"
                                  ItemsSource="{x:Static models:Constants.AVAILABLE_CURRENCIES}"
                                  Theme="{StaticResource MenuComboBox}"
                                  HorizontalAlignment="Right"
                                  SelectedItem="{CompiledBinding SelectedCurrency}"
                                  ItemContainerTheme="{StaticResource MenuComboBoxItem}"
                                  Width="80" Height="28"
                                  AutoScrollToSelectedItem="True">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                            <ComboBox.Resources>
                                <ResourceDictionary>
                                    <ResourceDictionary.MergedDictionaries>
                                        <ResourceInclude Source="/Styles/CollectionControlThemes.xaml"/>
                                    </ResourceDictionary.MergedDictionaries>
                                </ResourceDictionary>
                            </ComboBox.Resources>
                        </ComboBox>
                    </Grid>
                </StackPanel>

                <!-- Quick Actions -->
                <Border Classes="divider"/>
                <StackPanel Margin="20,14,20,14" Spacing="10">
                    <TextBlock Text="QUICK ACTIONS" Classes="section-title"/>
                    <WrapPanel>
                        <WrapPanel.Styles>
                            <Style Selector="Button">
                                <Setter Property="Margin" Value="3"/>
                                <Setter Property="Width" Value="36"/>
                                <Setter Property="Height" Value="36"/>
                                <Setter Property="FontSize" Value="15"/>
                                <Setter Property="ToolTip.Placement" Value="Bottom"/>
                                <Setter Property="ToolTip.VerticalOffset" Value="5"/>
                            </Style>
                        </WrapPanel.Styles>
                        <Button Theme="{StaticResource MenuButton}" Click="OpenApplicationFolder" ToolTip.Tip="App Folder" i:Attached.Icon="fa7-solid fa7-folder-open"/>
                        <Button Theme="{StaticResource MenuButton}" Click="OpenCoversFolder" ToolTip.Tip="Covers Folder" i:Attached.Icon="fa7-solid fa7-image"/>
                        <Button Theme="{StaticResource MenuButton}" Click="OpenScreenshotsFolder" ToolTip.Tip="Screenshots" i:Attached.Icon="fa7-solid fa7-camera-retro"/>
                        <Button Theme="{StaticResource MenuButton}" Click="OpenThemesFolder" ToolTip.Tip="Themes Folder" i:Attached.Icon="fa7-solid fa7-swatchbook"/>
                        <Button Theme="{StaticResource MenuButton}" Click="ReportBug" ToolTip.Tip="Report Bug" i:Attached.Icon="fa7-solid fa7-bug"/>
                        <Button x:Name="ExportToSpreadSheetButton" Theme="{StaticResource MenuButton}" Click="ExportToSpreadSheetAsync" ToolTip.Tip="Export CSV" i:Attached.Icon="fa7-solid fa7-file-csv"/>
                        <Button Theme="{StaticResource MenuButton}" Click="OpenCoolorsSite" ToolTip.Tip="Coolors" i:Attached.Icon="fa7-solid fa7-palette"/>
                        <Button Theme="{StaticResource MenuButton}" Click="JoinDiscord" ToolTip.Tip="Discord" i:Attached.Icon="fa7-brands fa7-discord"/>
                    </WrapPanel>
                </StackPanel>

                <!-- Controls (collapsible) -->
                <Border Classes="divider"/>
                <StackPanel Margin="20,14,20,14" Spacing="4">
                    <Button Theme="{StaticResource MenuButton}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="10,6" Click="ToggleControlsSection">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="CONTROLS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TsundokuMenuButtonTextAndIconColor}" LetterSpacing="1" VerticalAlignment="Center"/>
                            <i:Icon Grid.Column="1" Value="fa7-solid fa7-chevron-down" FontSize="11" Foreground="{DynamicResource TsundokuMenuButtonTextAndIconColor}" VerticalAlignment="Center" Name="ControlsChevron"/>
                        </Grid>
                    </Button>
                    <StackPanel Name="ControlsContent" IsVisible="False" Spacing="4" Margin="0,6,0,0">
                        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                            <TextBlock Text="Copy Title on Series Card" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TsundokuMenuTextColor}"/>
                            <Border Grid.Column="1" Background="{DynamicResource TsundokuMenuButtonBGColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="2" CornerRadius="5" Padding="6,2">
                                <TextBlock Text="Click Title" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TsundokuMenuButtonTextAndIconColor}"/>
                            </Border>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                            <TextBlock Text="Open Series Page" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TsundokuMenuTextColor}"/>
                            <Border Grid.Column="1" Background="{DynamicResource TsundokuMenuButtonBGColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="2" CornerRadius="5" Padding="6,2">
                                <TextBlock Text="Click Image" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TsundokuMenuButtonTextAndIconColor}"/>
                            </Border>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                            <TextBlock Text="Toggle Fullscreen" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TsundokuMenuTextColor}"/>
                            <Border Grid.Column="1" Background="{DynamicResource TsundokuMenuButtonBGColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="2" CornerRadius="5" Padding="6,2">
                                <TextBlock Text="F11" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TsundokuMenuButtonTextAndIconColor}"/>
                            </Border>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                            <TextBlock Text="Advanced Search" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TsundokuMenuTextColor}"/>
                            <Border Grid.Column="1" Background="{DynamicResource TsundokuMenuButtonBGColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="2" CornerRadius="5" Padding="6,2">
                                <TextBlock Text="CTRL + F" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TsundokuMenuButtonTextAndIconColor}"/>
                            </Border>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                            <TextBlock Text="Screenshot Collection" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TsundokuMenuTextColor}"/>
                            <Border Grid.Column="1" Background="{DynamicResource TsundokuMenuButtonBGColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="2" CornerRadius="5" Padding="6,2">
                                <TextBlock Text="CTRL + P" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TsundokuMenuButtonTextAndIconColor}"/>
                            </Border>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                            <TextBlock Text="Reload Filter/Sort" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TsundokuMenuTextColor}"/>
                            <Border Grid.Column="1" Background="{DynamicResource TsundokuMenuButtonBGColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="2" CornerRadius="5" Padding="6,2">
                                <TextBlock Text="SHIFT + R" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TsundokuMenuButtonTextAndIconColor}"/>
                            </Border>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                            <TextBlock Text="Save Collection" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TsundokuMenuTextColor}"/>
                            <Border Grid.Column="1" Background="{DynamicResource TsundokuMenuButtonBGColor}" BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" BorderThickness="2" CornerRadius="5" Padding="6,2">
                                <TextBlock Text="CTRL + S" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TsundokuMenuButtonTextAndIconColor}"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <!-- Youtubers (collapsible) -->
                <Border Classes="divider"/>
                <StackPanel Margin="20,14,20,14" Spacing="10">
                    <Button Theme="{StaticResource MenuButton}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="10,6" Click="ToggleYoutubersSection">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="YOUTUBERS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TsundokuMenuButtonTextAndIconColor}" LetterSpacing="1" VerticalAlignment="Center"/>
                            <i:Icon Grid.Column="1" Value="fa7-solid fa7-chevron-down" FontSize="11" Foreground="{DynamicResource TsundokuMenuButtonTextAndIconColor}" VerticalAlignment="Center" Name="YoutubersChevron"/>
                        </Grid>
                    </Button>
                    <WrapPanel Name="YoutubersContent" IsVisible="False">
                        <WrapPanel.Styles>
                            <Style Selector="Button">
                                <Setter Property="Margin" Value="3"/>
                            </Style>
                        </WrapPanel.Styles>
                        <Button Theme="{StaticResource MenuButton}" Click="OpenYoutuberSite" x:Name="EastCoastManga" Content="EastCoastManga" Padding="10,6" FontSize="12"/>
                        <Button Theme="{StaticResource MenuButton}" Click="OpenYoutuberSite" x:Name="PlasmsManga" Content="Plasm's Manga" Padding="10,6" FontSize="12"/>
                        <Button Theme="{StaticResource MenuButton}" Click="OpenYoutuberSite" x:Name="hvlmanga" Content="hvlmanga" Padding="10,6" FontSize="12"/>
                        <Button Theme="{StaticResource MenuButton}" Click="OpenYoutuberSite" x:Name="JakeThePog" Content="Jake The Pog" Padding="10,6" FontSize="12"/>
                        <Button Theme="{StaticResource MenuButton}" Click="OpenYoutuberSite" x:Name="DanielPeppers" Content="Daniel Peppers" Padding="10,6" FontSize="12"/>
                        <Button Theme="{StaticResource MenuButton}" Click="OpenYoutuberSite" x:Name="Ararawgi" Content="Ararawgi" Padding="10,6" FontSize="12"/>
                        <Button Theme="{StaticResource MenuButton}" Click="OpenYoutuberSite" x:Name="TheMangaSloth" Content="TheMangaSloth" Padding="10,6" FontSize="12"/>
                        <Button Theme="{StaticResource MenuButton}" Click="OpenYoutuberSite" x:Name="mangageekdom" Content="MANGA GEEKDOM" Padding="10,6" FontSize="12"/>
                        <Button Theme="{StaticResource MenuButton}" Click="OpenYoutuberSite" x:Name="meettheweebfamily" Content="Meet the Weeb Family" Padding="10,6" FontSize="12"/>
                    </WrapPanel>
                </StackPanel>

                <!-- Data / Version -->
                <Border Classes="divider"/>
                <StackPanel Margin="20,14,20,14" Spacing="10">
                    <TextBlock Text="DATA" Classes="section-title"/>
                    <WrapPanel>
                        <WrapPanel.Styles>
                            <Style Selector="Button">
                                <Setter Property="Margin" Value="3"/>
                            </Style>
                        </WrapPanel.Styles>
                        <Button Theme="{StaticResource MenuButton}" Click="OpenAniListLink" x:Name="AniListCredit" Content="AniList" Padding="10,6" FontSize="12"/>
                        <Button Theme="{StaticResource MenuButton}" Click="OpenMangadexLink" x:Name="MangadexCredit" Content="Mangadex" Padding="10,6" FontSize="12"/>
                        <Button Theme="{StaticResource MenuButton}" Click="RefreshAllCoversAsync" x:Name="RefreshSeriesButton" Content="Refresh Series" Padding="10,6" FontSize="12"/>
                        <Button Theme="{StaticResource MenuButton}" Click="ImportUserDataAsync" x:Name="ImportUserData" Content="Json Import" Padding="10,6" FontSize="12"/>
                        <Button Theme="{StaticResource MenuButton}" Click="ImportLibibDataAsync" x:Name="ImportLibibData" Content="Libib Import" Padding="10,6" FontSize="12"/>
                        <Button Theme="{StaticResource MenuButton}" Click="ImportGoodreadsDataAsync" x:Name="ImportGoodreadsData" Content="Goodreads Import" Padding="10,6" FontSize="12"/>
                        <Button Theme="{StaticResource MenuButton}" Click="ShowChangelogAsync" Content="What's New" Padding="10,6" FontSize="12"/>
                        <Button Theme="{StaticResource MenuButton}" Click="CheckApiStatusAsync" x:Name="CheckApiStatusButton" Content="Check API Status" Padding="10,6" FontSize="12"/>
                        <Button Theme="{StaticResource MenuButton}" Click="RepairUserDataAsync" x:Name="RepairDataButton" Content="Repair Data" Padding="10,6" FontSize="12"/>
                    </WrapPanel>
                </StackPanel>

                <!-- Version -->
                <TextBlock Text="{CompiledBinding Source={x:Static vm:ViewModelBase.CUR_TSUNDOKU_VERSION}, StringFormat='v{0}'}"
                           HorizontalAlignment="Center"
                           FontSize="12"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TsundokuSeriesCardStaffColor}"
                           Opacity="0.5"
                           Margin="0,0,0,12"
                           Cursor="Hand"
                           PointerPressed="OpenReleasesPage"/>
            </StackPanel>
        </ScrollViewer>
        </Grid>
    </Border>
</Window>
