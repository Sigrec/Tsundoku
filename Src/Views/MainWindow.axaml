<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:enums="clr-namespace:Tsundoku.Models.Enums"
		xmlns:m="clr-namespace:Tsundoku.Models"
        xmlns:vm="clr-namespace:Tsundoku.ViewModels"
		xmlns:help="clr-namespace:Tsundoku.Helpers"
		xmlns:cv="clr-namespace:Tsundoku.Converters"
		xmlns:controls="clr-namespace:Tsundoku.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:i="clr-namespace:Projektanker.Icons.Avalonia;assembly=Projektanker.Icons.Avalonia"
        x:Class="Tsundoku.Views.MainWindow"
        Icon="\Assets\Icons\TsundokuLogo.ico"
        Title="Tsundoku"
		Name="TsundokuWindow"
		FontFamily="{StaticResource TsundokuFontFamily}"
		MinWidth="1000"
		MinHeight="500"
		WindowStartupLocation="1"
		WindowState="2"
		KeyboardNavigation.TabNavigation="None"
		x:DataType="vm:MainWindowViewModel">

	<Window.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceInclude Source="/Styles/CollectionControlThemes.xaml"/>
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</Window.Resources>

    <Panel Name="TsundokuPanel">
        <!-- Notification Popup -->
        <Border Name="NotificationPopup"
                ZIndex="2" 
                IsVisible="false" 
                BorderThickness="2" 
                CornerRadius="8" 
                ClipToBounds="True" 
                BorderBrush="{DynamicResource TsundokuMenuButtonBorderColor}" 
                BoxShadow="0 0 15 6 #B3000000" 
                Margin="0,20,0,0" 
                Height="50" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Top" 
                Background="{DynamicResource TsundokuStatusAndBookTypeBGColor}">
            <Grid RowDefinitions="Auto" ColumnDefinitions="Auto,5,Auto,2,Auto" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0,10,0">
                    <Grid.Styles>
                        <Style Selector="Button">
                            <Style Selector="^:pointerover /template/ ContentPresenter">
                                <Setter Property="TextBlock.Foreground" Value="{DynamicResource TsundokuSeriesButtonIconHoverColor}"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </Style>
                    </Grid.Styles>
                    <i:Icon Value="fa-solid fa-bell" FontSize="25" FontWeight="Bold" Foreground="{DynamicResource TsundokuMenuButtonTextAndIconColor}" Classes="Menu"/>
                    <TextBlock 
                        Grid.Column="2"
                        Text="{CompiledBinding NotificationText, Mode=OneWay}" 
                        FontSize="18" 
                        TextAlignment="Center" 
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontWeight="Bold" 
                        TextWrapping="Wrap" 
                        Classes="Menu" 
                        Foreground="{DynamicResource TsundokuMenuButtonTextAndIconColor}"/>
            </Grid>
        </Border>

        <!-- Advanced Search Popup -->
        <Panel Name="AdvancedSearchPopup" ZIndex="1" IsVisible="false">
            <Rectangle Fill="Black" Opacity="0.55"/>
            <StackPanel Margin="0,140,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        MinWidth="480"
                        MaxWidth="700"
                        Spacing="4">
                <controls:FilterBuilder DataContext="{CompiledBinding FilterBuilder}"/>
                <TextBlock Text="{CompiledBinding AdvancedSearchQueryErrorMessage}"
                           IsVisible="{CompiledBinding AdvancedSearchQueryErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           FontSize="13" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TsundokuSearchBarTextColor}"/>
            </StackPanel>
        </Panel>

        <!-- Back to Top Button -->
        <Border ZIndex="1"
                Name="BackToTopButton"
                IsVisible="False"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="16,0,0,16"
                CornerRadius="12"
                BoxShadow="0 4 16 0 #4D000000"
                Opacity="0">
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25"/>
                </Transitions>
            </Border.Transitions>
            <Button Width="44" Height="44"
                    CornerRadius="12"
                    Theme="{StaticResource MenuButton}"
                    i:Attached.Icon="fa-solid fa-chevron-up"
                    FontSize="18"
                    Cursor="Hand"
                    Click="BackToTop_Click"/>
        </Border>

        <!-- Theme Selector (floating bottom-right, extra right margin for scrollbar) -->
        <StackPanel ZIndex="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,32,16"
                    Spacing="8">
            <!-- Theme List Popup -->
            <Border Name="ThemeGrid"
                    IsVisible="False"
                    Background="{DynamicResource TsundokuMenuBGColor}"
                    BorderBrush="{DynamicResource TsundokuDividerColor}"
                    BorderThickness="2"
                    CornerRadius="14"
                    BoxShadow="0 12 40 0 #66000000"
                    Padding="10"
                    MinWidth="240"
                    MaxHeight="400">
                <StackPanel Spacing="4">
                    <TextBlock Text="THEMES"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TsundokuMenuButtonTextAndIconColor}"
                               Opacity="0.5"
                               TextAlignment="Center"
                               Padding="0,0,0,2"
                               LetterSpacing="1"/>
                    <Border Height="2" Background="{DynamicResource TsundokuDividerColor}" Opacity="0.3" Margin="0,0,0,4"/>
                    <ListBox Name="ThemeListItems"
                             ItemsSource="{CompiledBinding SavedThemes}"
                             SelectionChanged="ThemeSelectionChanged"
                             Background="Transparent"
                             BorderThickness="0"
                             MaxHeight="340"
                             ScrollViewer.VerticalScrollBarVisibility="Hidden"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Cursor="Hand">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource TsundokuMenuButtonTextAndIconColor}"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="Margin" Value="0,1"/>
                                <Setter Property="CornerRadius" Value="10"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                            </Style>
                            <Style Selector="ListBoxItem:pointerover">
                                <Setter Property="Background" Value="{DynamicResource TsundokuMenuButtonBGColor}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource TsundokuMenuButtonBorderColor}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TsundokuMenuButtonTextAndIconColor}"/>
                            </Style>
                            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="{DynamicResource TsundokuMenuButtonBGColor}"/>
                            </Style>
                            <Style Selector="ListBoxItem:selected">
                                <Setter Property="Background" Value="{DynamicResource TsundokuMenuButtonBGHoverColor}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource TsundokuMenuButtonBorderHoverColor}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TsundokuMenuButtonTextAndIconHoverColor}"/>
                            </Style>
                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="{DynamicResource TsundokuMenuButtonBGHoverColor}"/>
                            </Style>
                            <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="{DynamicResource TsundokuMenuButtonBGHoverColor}"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="m:TsundokuTheme">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border CornerRadius="5" ClipToBounds="True" BorderThickness="2" BorderBrush="#26FFFFFF" Padding="2">
                                        <StackPanel Orientation="Horizontal" Spacing="2">
                                            <Border Width="12" Height="20" CornerRadius="3" Background="{CompiledBinding MenuBGColor}"/>
                                            <Border Width="12" Height="20" CornerRadius="3" Background="{CompiledBinding CollectionBGColor}"/>
                                            <Border Width="12" Height="20" CornerRadius="3" Background="{CompiledBinding SeriesCardBGColor}"/>
                                            <Border Width="12" Height="20" CornerRadius="3" Background="{CompiledBinding SeriesCardTitleColor}"/>
                                            <Border Width="12" Height="20" CornerRadius="3" Background="{CompiledBinding SeriesProgressBarColor}"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="{CompiledBinding ThemeName}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
            <!-- Toggle Button -->
            <Border HorizontalAlignment="Right"
                    CornerRadius="12"
                    BoxShadow="0 4 16 0 #4D000000">
                <Button Width="44" Height="44"
                        CornerRadius="12"
                        Theme="{StaticResource MenuButton}"
                        i:Attached.Icon="fa-solid fa-swatchbook"
                        FontSize="18"
                        Cursor="Hand"
                        Click="ToggleThemeSelector"/>
            </Border>
        </StackPanel>

        <DockPanel ZIndex="0">
            <!-- Menu -->
            <Border Name="Navigation"
                    DockPanel.Dock="Top"
                    Classes="Menu"
                    Background="{DynamicResource TsundokuMenuBGColor}"
                    BorderBrush="{DynamicResource TsundokuDividerColor}"
                    BorderThickness="0,0,0,2"
                    Padding="24,12">
                <Grid RowDefinitions="Auto,8,Auto">
                    <!-- Row 0: User Area + Search -->
                    <Grid ColumnDefinitions="Auto,*">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <!-- Brand -->
                            <Image Source="/Assets/Icons/TsundokuLogo.ico"
                                   Width="32" Height="32"/>
                            <TextBlock Text="Tsundoku"
                                       FontSize="17"
                                       FontWeight="ExtraBold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TsundokuUsernameColor}"/>

                            <!-- Divider -->
                            <Rectangle Width="1" Height="24"
                                       Fill="{DynamicResource TsundokuDividerColor}"
                                       Opacity="0.5"/>

                            <!-- User -->
                            <Border BorderThickness="2" BorderBrush="{DynamicResource TsundokuDividerColor}" CornerRadius="16" ClipToBounds="True" Height="32" Width="32">
                                <Image Height="32" Width="32"
                                       Source="{CompiledBinding CurrentUser.UserIcon}"
                                       Cursor="Hand"
                                       PointerPressed="ChangeUserIcon"
                                       ClipToBounds="True"
                                       ToolTip.Tip="Change Icon"
                                       Name="IconImage"/>
                            </Border>
                            <TextBlock Name="Username"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Text="{CompiledBinding CurrentUser.UserName, Mode=OneWay}"
                                       Classes="username"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Background="{DynamicResource TsundokuSearchBarBGColor}"
                                BorderBrush="{DynamicResource TsundokuSearchBarBorderColor}"
                                BorderThickness="2"
                                CornerRadius="10"
                                Width="320"
                                Height="34"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                            <Grid ColumnDefinitions="Auto,*">
                                <i:Icon Grid.Column="0"
                                        Value="fa-solid fa-magnifying-glass"
                                        FontSize="13"
                                        Foreground="{DynamicResource TsundokuSearchBarTextColor}"
                                        Opacity="0.5"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        IsHitTestVisible="False"/>
                                <TextBox Name="SearchBar"
                                         Grid.Column="1"
                                         Text="{CompiledBinding SeriesFilterText, Mode=TwoWay}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{DynamicResource TsundokuSearchBarTextColor}"
                                         CaretBrush="{DynamicResource TsundokuSearchBarTextColor}"
                                         FontWeight="Bold"
                                         Watermark="Search collection..."
                                         FontSize="13"
                                         VerticalAlignment="Center"
                                         Padding="8,2,10,0"
                                         VerticalContentAlignment="Center">
                                    <TextBox.Styles>
                                        <Style Selector="TextBox /template/ Border#PART_BorderElement">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>
                                        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>
                                        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>
                                        <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
                                            <Setter Property="Foreground" Value="{DynamicResource TsundokuSearchBarTextColor}"/>
                                            <Setter Property="Opacity" Value="0.4"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                        <Style Selector="TextBox /template/ DockPanel">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                        <Style Selector="TextBox /template/ ScrollViewer#PART_ScrollViewer">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </TextBox.Styles>
                                </TextBox>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Row 2: Action Buttons + Controls -->
                    <Grid Grid.Row="2" ColumnDefinitions="Auto,*">
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <StackPanel.Styles>
                                <Style Selector="ToggleButton">
                                    <Setter Property="ToolTip.Placement" Value="Bottom"/>
                                    <Setter Property="ToolTip.VerticalOffset" Value="5"/>
                                </Style>
                            </StackPanel.Styles>
                            <ToggleButton Name="SettingsButton"
                                    i:Attached.Icon="fa-solid fa-gear"
                                    Width="34" Height="34" FontSize="14"
                                    Theme="{StaticResource MenuToggleButton}"
                                    ToolTip.Tip="Settings"
                                    Cursor="Hand"
                                    Click="OpenSettingsDialog"/>
                            <ToggleButton Name="UserNotesButton"
                                    i:Attached.Icon="fa-solid fa-note-sticky"
                                    Width="34" Height="34" FontSize="14"
                                    Theme="{StaticResource MenuToggleButton}"
                                    ToolTip.Tip="Notes"
                                    Cursor="Hand"
                                    Click="OpenUserNotesDialog"/>
                            <ToggleButton Name="AddNewSeriesButton"
                                    i:Attached.Icon="fa-solid fa-square-plus"
                                    Width="34" Height="34" FontSize="14"
                                    Theme="{StaticResource MenuToggleButton}"
                                    ToolTip.Tip="Add Series"
                                    Cursor="Hand"
                                    Click="OpenAddSeriesDialog"/>
                            <ToggleButton Name="ThemeButton"
                                    i:Attached.Icon="fa-solid fa-swatchbook"
                                    Width="34" Height="34" FontSize="14"
                                    Theme="{StaticResource MenuToggleButton}"
                                    ToolTip.Tip="Theme"
                                    Cursor="Hand"
                                    Click="OpenThemeSettingsDialog"/>
                            <ToggleButton Name="StatsButton"
                                    i:Attached.Icon="fa-solid fa-chart-simple"
                                    Width="34" Height="34" FontSize="14"
                                    Theme="{StaticResource MenuToggleButton}"
                                    ToolTip.Tip="Stats"
                                    Cursor="Hand"
                                    Click="OpenCollectionStatsDialog"/>
                            <ToggleButton Name="AnalysisButton"
                                    i:Attached.Icon="fa-solid fa-table-list"
                                    Width="34" Height="34" FontSize="14"
                                    Theme="{StaticResource MenuToggleButton}"
                                    ToolTip.Tip="Analysis"
                                    Cursor="Hand"
                                    Click="OpenPriceAnalysisDialog"/>
                            <Button Name="DonateButton"
                                    Theme="{StaticResource MenuButton}"
                                    i:Attached.Icon="fa-solid fa-circle-dollar-to-slot"
                                    Width="34" Height="34" FontSize="14"
                                    ToolTip.Tip="Donate"
                                    ToolTip.Placement="Bottom"
                                    ToolTip.VerticalOffset="5"
                                    Cursor="Hand"
                                    Click="OpenDonationLink"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="LANGUAGE" FontSize="11" FontWeight="SemiBold" Opacity="0.5" VerticalAlignment="Center" Foreground="{DynamicResource TsundokuMenuTextColor}"/>
                            <ComboBox Name="LanguageSelector"
                                    ItemsSource="{x:Static enums:TsundokuLanguageModel.LANGUAGES}"
                                    SelectionChanged="LanguageChanged"
                                    Height="34"
                                    SelectedIndex="{CompiledBinding SelectedLangIndex}"
                                    AutoScrollToSelectedItem="True"
                                    Cursor="Hand"
                                    VerticalContentAlignment="Center"
                                    ItemContainerTheme="{StaticResource MenuComboBoxItem}"
                                    Theme="{StaticResource MenuComboBox}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                            </ComboBox>

                            <Rectangle Width="1" Height="18" Fill="{DynamicResource TsundokuDividerColor}" Opacity="0.4" Margin="4,0"/>

                            <TextBlock Text="SORT" FontSize="11" FontWeight="SemiBold" Opacity="0.5" VerticalAlignment="Center" Foreground="{DynamicResource TsundokuMenuTextColor}"/>
                            <ComboBox Name="SortSelector"
                                    ItemsSource="{x:Static enums:TsundokuSortModel.TSUNDOKU_SORT_LIST}"
                                    SelectionChanged="SortChanged"
                                    Height="34"
                                    SelectedIndex="{CompiledBinding SelectedSortIndex}"
                                    AutoScrollToSelectedItem="True"
                                    Cursor="Hand"
                                    VerticalContentAlignment="Center"
                                    ItemContainerTheme="{StaticResource MenuComboBoxItem}"
                                    Theme="{StaticResource MenuComboBox}"/>

                            <Rectangle Width="1" Height="18" Fill="{DynamicResource TsundokuDividerColor}" Opacity="0.4" Margin="4,0"/>

                            <TextBlock Text="FILTER" FontSize="11" FontWeight="SemiBold" Opacity="0.5" VerticalAlignment="Center" Foreground="{DynamicResource TsundokuMenuTextColor}"/>
                            <ComboBox Name="CollectionFilterSelector"
                                    SelectionChanged="CollectionFilterChanged"
                                    ItemsSource="{x:Static enums:TsundokuFilterModel.TSUNDOKU_FILTER_LIST}"
                                    Height="34"
                                    SelectedIndex="{CompiledBinding SelectedFilterIndex}"
                                    PlaceholderText="All"
                                    Cursor="Hand"
                                    VerticalContentAlignment="Center"
                                    ItemContainerTheme="{StaticResource MenuComboBoxItem}"
                                    Theme="{StaticResource MenuComboBox}"/>
                            <Button Name="ClearFilterButton"
                                    Theme="{StaticResource MenuButton}"
                                    i:Attached.Icon="fa-solid fa-xmark"
                                    Width="24" Height="24" FontSize="11"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    Click="ClearFilterClicked"
                                    ToolTip.Tip="Clear Filter"
                                    IsVisible="False"/>

                            <Rectangle Width="1" Height="18" Fill="{DynamicResource TsundokuDividerColor}" Opacity="0.4" Margin="4,0"/>

                            <TextBlock Text="PUBLISHER" FontSize="11" FontWeight="SemiBold" Opacity="0.5" VerticalAlignment="Center" Foreground="{DynamicResource TsundokuMenuTextColor}"/>
                            <ComboBox Name="PublisherFilterSelector"
                                    SelectionChanged="PublisherFilterChanged"
                                    ItemsSource="{CompiledBinding AvailablePublishers}"
                                    Height="34"
                                    SelectedItem="{CompiledBinding SelectedPublisher}"
                                    PlaceholderText="All"
                                    Cursor="Hand"
                                    VerticalContentAlignment="Center"
                                    ItemContainerTheme="{StaticResource MenuComboBoxItem}"
                                    Theme="{StaticResource MenuComboBox}"/>
                            <Button Name="ClearPublisherFilter"
                                    Theme="{StaticResource MenuButton}"
                                    i:Attached.Icon="fa-solid fa-xmark"
                                    Width="24" Height="24" FontSize="11"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    Click="ClearPublisherFilterClicked"
                                    ToolTip.Tip="Clear Publisher"
                                    IsVisible="{CompiledBinding SelectedPublisher, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Collection -->
            <ScrollViewer Name="CollectionPane" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" IsScrollInertiaEnabled="True" DockPanel.Dock="Bottom" Theme="{StaticResource CollectionScroll}" Background="{DynamicResource TsundokuCollectionBGColor}">
                <ItemsRepeater Name="CollectionItems" Margin="20,30,20,30" ItemsSource="{CompiledBinding UserCollection}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout
                            Orientation="Horizontal"
                            ItemsJustification="Center"/>
                    </ItemsRepeater.Layout>

                    <ItemsRepeater.ItemTemplate>
                         <DataTemplate DataType="m:Series">
                            <controls:SeriesCardDisplay
                                Series="{CompiledBinding}"
                                Language="{CompiledBinding $parent[Window].((vm:MainWindowViewModel)DataContext).CurrentUser.Language}" />
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
		    </ScrollViewer>
	    </DockPanel>
    </Panel>
</Window>