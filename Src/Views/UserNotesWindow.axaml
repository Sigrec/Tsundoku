<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Tsundoku.ViewModels"
        xmlns:i="clr-namespace:Projektanker.Icons.Avalonia;assembly=Projektanker.Icons.Avalonia"
        x:Class="Tsundoku.Views.UserNotesWindow"
        Title="Notes"
        Icon="\Assets\Icons\TsundokuLogo.ico"
        Classes="Menu"
        Width="650"
        Height="500"
        MinWidth="500"
        MinHeight="350"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        x:DataType="vm:UserNotesWindowViewModel">

    <Border Classes="Menu" BorderThickness="2" CornerRadius="0,0,8,8" ClipToBounds="True">
        <Grid RowDefinitions="Auto,*">
            <!-- Header -->
            <Border Grid.Row="0" BorderThickness="0,0,0,2" BorderBrush="{DynamicResource TsundokuDividerColor}" Padding="16,12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <i:Icon Value="fa-solid fa-note-sticky" FontSize="16" Foreground="{DynamicResource TsundokuDividerColor}"/>
                    <TextBlock Text="Notes" FontSize="18" FontWeight="ExtraBold" Foreground="{DynamicResource TsundokuUsernameColor}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Notes Area -->
            <Grid Grid.Row="1" RowDefinitions="*,Auto" Margin="16">
                <Border Background="{DynamicResource TsundokuSeriesCardBGColor}"
                        BorderBrush="{DynamicResource TsundokuSeriesCardBorderColor}"
                        BorderThickness="2"
                        CornerRadius="10">
                    <TextBox Name="UserNotes"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource TsundokuSeriesCardDescColor}"
                             CaretBrush="{DynamicResource TsundokuSeriesCardDescColor}"
                             FontWeight="SemiBold"
                             FontSize="{CompiledBinding NotesFontSize}"
                             TextWrapping="Wrap"
                             Watermark="Notes..."
                             Text="{CompiledBinding Notes}"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             Padding="14"
                             VerticalContentAlignment="Top">
                        <TextBox.Styles>
                            <Style Selector="TextBox /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                            <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                            <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                            <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
                                <Setter Property="Foreground" Value="{DynamicResource TsundokuSeriesCardDescColor}"/>
                                <Setter Property="Opacity" Value="0.3"/>
                            </Style>
                        </TextBox.Styles>
                    </TextBox>
                </Border>

                <!-- Font Size Slider (horizontal, bottom) -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="A" FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource TsundokuDividerColor}"
                               VerticalAlignment="Center"/>
                    <Slider Name="FontSizeSlider"
                            Orientation="Horizontal"
                            Minimum="8" Maximum="32" Value="{CompiledBinding NotesFontSize}"
                            Width="200"
                            TickFrequency="0.5"
                            IsSnapToTickEnabled="True"
                            SmallChange="0.5"
                            LargeChange="2"
                            Foreground="{DynamicResource TsundokuDividerColor}"/>
                    <TextBlock Text="A" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TsundokuDividerColor}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
