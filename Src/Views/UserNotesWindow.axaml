<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Tsundoku.ViewModels"
        xmlns:i="clr-namespace:Projektanker.Icons.Avalonia;assembly=Projektanker.Icons.Avalonia"
        xmlns:controls="clr-namespace:Tsundoku.Controls"
        x:Class="Tsundoku.Views.UserNotesWindow"
        Title="Notes"
        Icon="\Assets\Icons\TsundokuLogo.ico"
        Classes="Menu"
        Width="650"
        Height="500"
        MinWidth="500"
        MinHeight="350"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        x:DataType="vm:UserNotesWindowViewModel">

    <Border Classes="Menu" BorderThickness="2" CornerRadius="0,0,8,8" ClipToBounds="True">
        <Grid RowDefinitions="Auto,*">
            <!-- Header -->
            <controls:WindowHeader Grid.Row="0" Icon="fa-solid fa-note-sticky" Title="Notes"/>

            <!-- Notes Area -->
            <Grid Grid.Row="1" RowDefinitions="*,Auto" Margin="16">
                <TextBox Name="UserNotes"
                         Classes="Menu"
                         FontWeight="SemiBold"
                         FontSize="{CompiledBinding NotesFontSize}"
                         TextWrapping="Wrap"
                         Watermark="Notes..."
                         Text="{CompiledBinding Notes}"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         Padding="14"
                         VerticalContentAlignment="Top"/>

                <!-- Font Size Slider (horizontal, bottom) -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="A" FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource TsundokuDividerColor}"
                               VerticalAlignment="Center"/>
                    <Slider Name="FontSizeSlider"
                            Orientation="Horizontal"
                            Minimum="8" Maximum="32" Value="{CompiledBinding NotesFontSize}"
                            Width="200"
                            TickFrequency="0.5"
                            IsSnapToTickEnabled="True"
                            SmallChange="0.5"
                            LargeChange="2"
                            Foreground="{DynamicResource TsundokuDividerColor}">
                        <Slider.Styles>
                            <Style Selector="Slider /template/ Thumb">
                                <Setter Property="Background" Value="{DynamicResource TsundokuDividerColor}"/>
                            </Style>
                            <Style Selector="Slider /template/ Thumb:pointerover">
                                <Setter Property="Background" Value="{DynamicResource TsundokuMenuButtonBorderHoverColor}"/>
                            </Style>
                            <Style Selector="Slider /template/ Thumb:pressed">
                                <Setter Property="Background" Value="{DynamicResource TsundokuMenuButtonBorderHoverColor}"/>
                            </Style>
                            <Style Selector="Slider /template/ RepeatButton#PART_DecreaseButton">
                                <Setter Property="Background" Value="{DynamicResource TsundokuDividerColor}"/>
                            </Style>
                            <Style Selector="Slider /template/ RepeatButton#PART_IncreaseButton">
                                <Setter Property="Background" Value="{DynamicResource TsundokuMenuButtonBGColor}"/>
                            </Style>
                        </Slider.Styles>
                    </Slider>
                    <TextBlock Text="A" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TsundokuDividerColor}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
