<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Tsundoku.Views.SplashWindow"
        Icon="\Assets\Icons\TsundokuLogo.ico"
        WindowStartupLocation="CenterScreen"
        WindowDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        CanResize="False"
        ShowInTaskbar="True"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        Title="Tsundoku">

    <Border Background="{DynamicResource TsundokuMenuBGColor}"
            BorderBrush="{DynamicResource TsundokuDividerColor}"
            BorderThickness="2"
            CornerRadius="14"
            ClipToBounds="True"
            Padding="40,30">
        <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image Source="/Assets/Icons/TsundokuLogo.ico"
                   Width="64"
                   Height="64"
                   HorizontalAlignment="Center"/>
            <TextBlock Text="Tsundoku"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TsundokuUsernameColor}"
                       HorizontalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="2">
                <TextBlock x:Name="StatusText"
                           Text="Loading"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TsundokuDividerColor}"/>
                <TextBlock Text="·" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TsundokuDividerColor}" Opacity="0.3" Name="Dot1">
                    <TextBlock.Styles>
                        <Style Selector="TextBlock#Dot1">
                            <Style.Animations>
                                <Animation Duration="0:0:1.2" IterationCount="Infinite">
                                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.3"/></KeyFrame>
                                    <KeyFrame Cue="20%"><Setter Property="Opacity" Value="1"/></KeyFrame>
                                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.3"/></KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                    </TextBlock.Styles>
                </TextBlock>
                <TextBlock Text="·" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TsundokuDividerColor}" Opacity="0.3" Name="Dot2">
                    <TextBlock.Styles>
                        <Style Selector="TextBlock#Dot2">
                            <Style.Animations>
                                <Animation Duration="0:0:1.2" IterationCount="Infinite" Delay="0:0:0.2">
                                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.3"/></KeyFrame>
                                    <KeyFrame Cue="20%"><Setter Property="Opacity" Value="1"/></KeyFrame>
                                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.3"/></KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                    </TextBlock.Styles>
                </TextBlock>
                <TextBlock Text="·" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TsundokuDividerColor}" Opacity="0.3" Name="Dot3">
                    <TextBlock.Styles>
                        <Style Selector="TextBlock#Dot3">
                            <Style.Animations>
                                <Animation Duration="0:0:1.2" IterationCount="Infinite" Delay="0:0:0.4">
                                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.3"/></KeyFrame>
                                    <KeyFrame Cue="20%"><Setter Property="Opacity" Value="1"/></KeyFrame>
                                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.3"/></KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                    </TextBlock.Styles>
                </TextBlock>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
