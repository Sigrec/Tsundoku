<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Scoped scrollbar styles for series card description area -->
    <Style Selector="ScrollViewer.card-desc">
        <Setter Property="IsScrollChainingEnabled" Value="False" />
    </Style>
    <Style Selector="ScrollViewer.card-desc ScrollBar:vertical">
        <Style Selector="^ /template/ Rectangle#TrackRect">
            <Setter Property="Fill" Value="{DynamicResource TsundokuCollectionBGColor}" />
        </Style>
        <Style Selector="^ /template/ Thumb">
            <Setter Property="Background" Value="{DynamicResource TsundokuDividerColor}" />
            <Style Selector="^:pointerover /template/ Border">
                <Setter Property="Background" Value="{DynamicResource TsundokuDividerColor}" />
            </Style>
            <Style Selector="^:pressed /template/ Border">
                <Setter Property="Background" Value="{DynamicResource TsundokuDividerColor}" />
            </Style>
        </Style>
        <Style Selector="^[IsExpanded=true]">
            <Style Selector="^ /template/ Thumb">
                <Setter Property="Background" Value="{DynamicResource TsundokuDividerColor}" />
            </Style>
            <Style Selector="^ /template/ PathIcon">
                <Setter Property="Foreground" Value="{DynamicResource TsundokuDividerColor}" />
            </Style>
            <Style Selector="^ /template/ Rectangle#TrackRect">
                <Setter Property="Fill" Value="{DynamicResource TsundokuMenuBGColor}" />
            </Style>
        </Style>
        <Style Selector="^ /template/ RepeatButton#PART_LineUpButton, ^ /template/ RepeatButton#PART_LineDownButton">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TsundokuDividerColor}" />
            <Style Selector="^:pointerover">
                <Setter Property="TextElement.Foreground" Value="{DynamicResource TsundokuMenuButtonTextAndIconHoverColor}" />
                <Style Selector="^ /template/ ContentPresenter">
                    <Setter Property="Background" Value="{DynamicResource TsundokuDividerColor}" />
                </Style>
                <Style Selector="^ PathIcon">
                    <Setter Property="Foreground" Value="{DynamicResource TsundokuCollectionBGColor}" />
                </Style>
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="TextElement.Foreground" Value="{DynamicResource TsundokuMenuBGColor}" />
                <Style Selector="^ /template/ ContentPresenter">
                    <Setter Property="Background" Value="{DynamicResource TsundokuDividerColor}" />
                </Style>
                <Style Selector="^ PathIcon">
                    <Setter Property="Foreground" Value="{DynamicResource TsundokuCollectionBGColor}" />
                </Style>
            </Style>
        </Style>
    </Style>
</Styles>
