<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Scoped scrollbar styles for series card description area -->
    <Style Selector="ScrollViewer.card-desc">
        <Setter Property="IsScrollChainingEnabled" Value="False" />
    </Style>
    <Style Selector="ScrollViewer.card-desc ScrollBar:vertical">
        <Setter Property="IsHitTestVisible" Value="False" />
        <Style Selector="^ /template/ Rectangle#TrackRect">
            <Setter Property="Fill" Value="Transparent" />
        </Style>
        <Style Selector="^ /template/ Thumb">
            <Setter Property="Background" Value="{DynamicResource TsundokuSeriesCardDividerColor}" />
            <Setter Property="Opacity" Value="0.6"/>
        </Style>
        <Style Selector="^ /template/ RepeatButton#PART_LineUpButton, ^ /template/ RepeatButton#PART_LineDownButton">
            <Setter Property="IsVisible" Value="False" />
        </Style>
    </Style>
</Styles>
