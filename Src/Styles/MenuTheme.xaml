<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		>

    <Style Selector="AutoCompleteBox.query">
        <Style Selector="^ /template/ ListBox">
            <Setter Property="ItemContainerTheme" Value="{StaticResource QueryListBoxItem}"/>
        </Style>
    </Style>

	<Style Selector="Border.Menu">
		<Setter Property="Background" Value="{DynamicResource TsundokuMenuBGColor}"/>
		<Setter Property="BorderBrush" Value="{DynamicResource TsundokuDividerColor}"/>
	</Style>

	<Style Selector="TextBlock">
		<Style Selector="^.Menu">
			<Setter Property="TextBlock.Foreground" Value="{DynamicResource TsundokuMenuTextColor}"/>
		</Style>

		<Style Selector="^.username">
			<Setter Property="TextBlock.Foreground" Value="{DynamicResource TsundokuUsernameColor}"/>
		</Style>
	</Style>
    
    <Style Selector="ComboBox.Theme > ComboBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TsundokuMenuButtonTextAndIconColor}"/>
        
        <Style Selector="^:pressed /template/ ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource TsundokuMenuButtonBGHoverColor}"/>
			<Setter Property="Foreground" Value="{DynamicResource TsundokuMenuButtonTextAndIconHoverColor}"/>
		</Style>

		<Style Selector="^:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource TsundokuMenuButtonBGHoverColor}"/>
			<Setter Property="Foreground" Value="{DynamicResource TsundokuMenuButtonTextAndIconHoverColor}"/>
		</Style>

		<Style Selector="^:selected">
			<Style Selector="^ /template/ ContentPresenter">
				<Setter Property="Background" Value="{DynamicResource TsundokuMenuButtonBGHoverColor}"/>
				<Setter Property="Foreground" Value="{DynamicResource TsundokuMenuButtonTextAndIconHoverColor}"/>
			</Style>

            <!-- <Style Selector="^:disabled /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource ComboBoxItemBackgroundSelectedDisabled}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ComboBoxItemBorderBrushSelectedDisabled}" />
                <Setter Property="TextBlock.Foreground" Value="{DynamicResource ComboBoxItemTextBlock.ForegroundSelectedDisabled}" />
            </Style> -->

            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource ComboBoxItemBackgroundSelectedPointerOver}" />
                <Setter Property="TextBlock.Foreground" Value="{DynamicResource ComboBoxItemForegroundSelectedPointerOver}" />
            </Style>

            <Style Selector="^:pressed /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource ComboBoxItemBackgroundSelectedPressed}" />
                <Setter Property="TextBlock.Foreground" Value="{DynamicResource ComboBoxItemForegroundSelectedPressed}" />
            </Style>
		</Style>
    </Style>

	<Style Selector="TextBox.Menu, MaskedTextBox.Menu">
		<Setter Property="Background" Value="{DynamicResource TsundokuSearchBarBGColor}"/>
		<Setter Property="BorderBrush" Value="{DynamicResource TsundokuSearchBarBorderColor}"/>
		<Setter Property="Foreground" Value="{DynamicResource TsundokuSearchBarTextColor}"/>
		<Setter Property="CaretBrush" Value="{DynamicResource TsundokuSearchBarTextColor}"/>
		<Setter Property="SelectionBrush" Value="{DynamicResource TsundokuSearchBarTextColor}"/>
		<Setter Property="SelectionForegroundBrush" Value="{DynamicResource TsundokuSearchBarBGColor}"/>
		<Setter Property="CornerRadius" Value="10"/>
		<Setter Property="BorderThickness" Value="2"/>

		<Style Selector="^ /template/ Border#PART_BorderElement">
			<Setter Property="Background" Value="{DynamicResource TsundokuSearchBarBGColor}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource TsundokuSearchBarBorderColor}"/>
			<Setter Property="BorderThickness" Value="2"/>
			<Setter Property="CornerRadius" Value="10"/>
		</Style>

		<Style Selector="^ /template/ TextBlock#PART_Watermark">
			<Setter Property="Foreground" Value="{DynamicResource TsundokuSearchBarTextColor}"/>
			<Setter Property="Opacity" Value="0.4"/>
		</Style>

		<Style Selector="^:pointerover /template/ Border#PART_BorderElement">
			<Setter Property="Background" Value="{DynamicResource TsundokuSearchBarBGColor}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource TsundokuSearchBarBorderColor}"/>
			<Setter Property="BorderThickness" Value="2"/>
			<Setter Property="CornerRadius" Value="10"/>
		</Style>

		<Style Selector="^:focus /template/ Border#PART_BorderElement">
			<Setter Property="Background" Value="{DynamicResource TsundokuSearchBarBGColor}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource TsundokuSearchBarBorderColor}"/>
			<Setter Property="BorderThickness" Value="2"/>
			<Setter Property="CornerRadius" Value="10"/>
		</Style>

        <Style Selector="^:disabled">
            <Setter Property="Foreground" Value="{DynamicResource TsundokuSearchBarTextColor}" />

            <Style Selector="^ /template/ Border#PART_BorderElement">
                <Setter Property="Background" Value="{DynamicResource TsundokuSearchBarBGColor}"/>
		        <Setter Property="BorderBrush" Value="{DynamicResource TsundokuSearchBarBorderColor}"/>
            </Style>
        </Style>

        <Style Selector="^ /template/ ScrollViewer#PART_ScrollViewer">
			<Setter Property="Theme" Value="{StaticResource ReverseCollectionScroll}"/>
		</Style>
	</Style>

	<!-- Section title style (UPPERCASE labels) -->
	<Style Selector="TextBlock.section-title">
		<Setter Property="FontSize" Value="11"/>
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="Foreground" Value="{DynamicResource TsundokuSeriesCardPublisherColor}"/>
		<Setter Property="LetterSpacing" Value="1"/>
		<Setter Property="Opacity" Value="0.8"/>
	</Style>

	<!-- Section divider -->
	<Style Selector="Border.divider">
		<Setter Property="BorderThickness" Value="0,2,0,0"/>
		<Setter Property="BorderBrush" Value="{DynamicResource TsundokuDividerColor}"/>
		<Setter Property="Opacity" Value="0.3"/>
	</Style>
</Styles>
